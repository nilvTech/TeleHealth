    // FILTERED LIST
    private IEnumerable<Patient> FilteredPatients => patients
        .Where(p =>
            (string.IsNullOrWhiteSpace(searchText)
                || p.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                || p.MRN.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            &&
            (string.IsNullOrWhiteSpace(selectedCondition)
                || p.Condition == selectedCondition)
            &&
            (string.IsNullOrWhiteSpace(selectedRisk)
                || p.Risk == selectedRisk)
        );

    // RISK CLASS
    private string GetRiskClass(string risk) => risk switch
    {
        "High" => "risk-high",
        "Medium" => "risk-medium",
        "Low" => "risk-low",
        _ => ""
    };

    // NAVIGATION
    private void ViewPatient(int id)
    {
        Nav.NavigateTo($"/provider/caremanagement/{id}");
    }

    private void AddPatient()
    {
        Nav.NavigateTo("/provider/addpatient");
    }

    // MODEL
    public class Patient
    {
