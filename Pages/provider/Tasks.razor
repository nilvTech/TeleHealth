@page "/provider/tasks"

@inject NavigationManager Nav

<div class="tasks-container">

    <!-- HEADER -->
    <div class="header">

        <div>
            <h2>Tasks / Follow-ups</h2>
        </div>

        <button class="btn-add"
                @onclick="GoToCreate">
            + Add Task
        </button>

    </div>

    <!-- FILTERS -->
    <div class="filter-bar">

        <input class="search-box"
               placeholder="Search task or patient..."
               @bind="SearchText" />

        <select class="filter-select"
                @bind="SelectedStatus">

            <option value="">All Status</option>
            <option>Pending</option>
            <option>In Progress</option>
            <option>Completed</option>

        </select>

    </div>

    <!-- TASK TABLE -->
    <div class="card">

        <table class="table">

            <thead>
                <tr>
                    <th>Task</th>
                    <th>Patient</th>
                    <th>Category</th>
                    <th>Priority</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Assigned To</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var task in FilteredTasks)
                {
                    <tr>

                        <td>
                            <div class="task-title">
                                @task.Name
                            </div>

                            <div class="task-desc">
                                @task.Description
                            </div>
                        </td>

                        <td>@task.Patient</td>

                        <td>
                            <span class="tag">
                                @task.Category
                            </span>
                        </td>

                        <td>
                            <span class="priority @GetPriorityClass(task.Priority)">
                                @task.Priority
                            </span>
                        </td>

                        <td>@task.DueDate.ToShortDateString()</td>

                        <td>
                            <span class="status @GetStatusClass(task.Status)">
                                @task.Status
                            </span>
                        </td>

                        <td>@task.AssignedTo</td>

                        <td class="action-cell">

                            <div class="action-menu"
                                 @onclick:stopPropagation="true">

                                <button class="menu-btn"
                                        @onclick="() => ToggleMenu(task)">
                                    ⋮
                                </button>

                                @if (task.ShowMenu)
                                {
                                    <div class="menu-dropdown">

                                        @if (task.Status != "Pending")
                                        {
                                            <button class="menu-item"
                                                    @onclick='@(() => HandleAction(() => UpdateStatus(task, "Pending")))'>

                                                <span>🕒</span>
                                                <span>Pending</span>

                                            </button>
                                        }

                                        @if (task.Status != "In Progress")
                                        {
                                            <button class="menu-item"
                                                    @onclick='@(() => HandleAction(() => UpdateStatus(task, "In Progress")))'>

                                                <span>⏳</span>
                                                <span>In Progress</span>

                                            </button>
                                        }

                                        @if (task.Status != "Completed")
                                        {
                                            <button class="menu-item"
                                                    @onclick='@(() => HandleAction(() => UpdateStatus(task, "Completed")))'>

                                                <span>✔</span>
                                                <span>Completed</span>

                                            </button>
                                        }

                                        <div class="menu-divider"></div>

                                        <button class="menu-item danger-item"
                                                @onclick='@(() => HandleAction(() => DeleteTask(task.Id)))'>

                                            <span>🗑</span>
                                            <span>Delete</span>

                                        </button>

                                    </div>
                                }

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

