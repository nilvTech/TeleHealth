    private IEnumerable<TaskModel> FilteredTasks =>
        tasks.Where(x =>
            (string.IsNullOrWhiteSpace(SearchText)
             || x.Name.Contains(SearchText, StringComparison.OrdinalIgnoreCase)
             || x.Patient.Contains(SearchText, StringComparison.OrdinalIgnoreCase))
            &&
            (string.IsNullOrWhiteSpace(SelectedStatus)
             || x.Status == SelectedStatus));

    private void GoToCreate()
    {
        Nav.NavigateTo("/provider/addtask");
    }

    private void HandleAction(Action action)
    {
        action.Invoke();

        foreach (var t in tasks)
        {
            t.ShowMenu = false;
        }
    }

    private void UpdateStatus(TaskModel task, string status)
    {
        task.Status = status;
    }

    private void ToggleMenu(TaskModel selectedTask)
    {
        foreach (var t in tasks)
        {
            if (t != selectedTask)
            {
                t.ShowMenu = false;
            }
        }

        selectedTask.ShowMenu = !selectedTask.ShowMenu;
    }

    private void DeleteTask(int id)
    {
        var task = tasks.FirstOrDefault(x => x.Id == id);

        if (task != null)
        {
            tasks.Remove(task);
        }

        foreach (var t in tasks)
        {
            t.ShowMenu = false;
        }
    }

    private string GetStatusClass(string status) => status switch
    {
        "Pending" => "status-pending",
        "In Progress" => "status-progress",
        "Completed" => "status-completed",
        _ => ""
    };

    private string GetPriorityClass(string priority) => priority switch
    {
        "High" => "priority-high",
        "Medium" => "priority-medium",
        "Low" => "priority-low",
        _ => ""
    };

    public class TaskModel
    {
        public int Id { get; set; }

        public string Name { get; set; } = "";

        public DateTime DueDate { get; set; }

        public string Patient { get; set; } = "";

        public string Status { get; set; } = "Pending";

        public string Priority { get; set; } = "";

        public string Category { get; set; } = "";

        public string AssignedTo { get; set; } = "";

        public string Description { get; set; } = "";

        public bool ShowMenu { get; set; }
    }
}