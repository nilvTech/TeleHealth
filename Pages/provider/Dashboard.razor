            Time="8:42 AM"
        },

        new()
        {
            Level="High",
            Patient="Tom Brown",
            Message="SpO2 dropped below 91%",
            Time="9:15 AM"
        },

        new()
        {
            Level="Medium",
            Patient="Lisa Kim",
            Message="Weight gain detected over 3 days",
            Time="1 day ago"
        }
    };

    private List<ActivityModel> Activities = new()
    {
        new()
        {
            Title="SOAP Note Signed",
            Description="Consultation completed for John Miller",
            Time="10 mins ago"
        },

        new()
        {
            Title="New Message Received",
            Description="Care coordinator sent update",
            Time="30 mins ago"
        },

        new()
        {
            Title="Order Completed",
            Description="MRI Brain imaging finalized",
            Time="1 hour ago"
        },

        new()
        {
            Title="Patient Joined Waiting Room",
            Description="Lisa Kim ready for consultation",
            Time="2 hours ago"
        }
    };

    public class AppointmentModel
    {
        public string Time { get; set; } = "";
        public string Patient { get; set; } = "";
        public int Age { get; set; }
        public string Condition { get; set; } = "";
        public string VisitType { get; set; } = "";
        public string Status { get; set; } = "";
    }

    public class TaskModel
    {
        public string Icon { get; set; } = "";
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Priority { get; set; } = "";
    }

    public class AlertModel
    {
        public string Level { get; set; } = "";
        public string Patient { get; set; } = "";
        public string Message { get; set; } = "";
        public string Time { get; set; } = "";
    }

    public class ActivityModel
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Time { get; set; } = "";
    }
}