        new AppointmentModel
        {
            Time="10:00 AM",
            Patient="Michael Brown",
            MRN="PT1002",
            Provider="Dr. David Wilson",
            Type="In-Person",
            Status="Scheduled",
            Reason="Blood Pressure Review"
        },

        new AppointmentModel
        {
            Time="11:00 AM",
            Patient="Emily Davis",
            MRN="PT1003",
            Provider="Dr. Anna Lee",
            Type="Telehealth",
            Status="Completed",
            Reason="Asthma Management"
        },

        new AppointmentModel
        {
            Time="12:00 PM",
            Patient="Robert Wilson",
            MRN="PT1004",
            Provider="Dr. James Carter",
            Type="In-Person",
            Status="Scheduled",
            Reason="Cardiac Consultation"
        },

        new AppointmentModel
        {
            Time="02:00 PM",
            Patient="Olivia White",
            MRN="PT1005",
            Provider="Dr. Emily Brown",
            Type="Telehealth",
            Status="Scheduled",
            Reason="COPD Monitoring"
        },

        new AppointmentModel
        {
            Time="03:00 PM",
            Patient="David Lee",
            MRN="PT1006",
            Provider="Dr. David Wilson",
            Type="In-Person",
            Status="Cancelled",
            Reason="Diabetes Review"
        },

        new AppointmentModel
        {
            Time="04:00 PM",
            Patient="Sophia Martinez",
            MRN="PT1007",
            Provider="Dr. Anna Lee",
            Type="Telehealth",
            Status="Scheduled",
            Reason="Weight Management"
        },

        new AppointmentModel
        {
            Time="05:00 PM",
            Patient="James Taylor",
            MRN="PT1008",
            Provider="Dr. James Carter",
            Type="In-Person",
            Status="Completed",
            Reason="Cardiac Follow-up"
        }
    };

    private IEnumerable<AppointmentModel> FilteredAppointments =>
        appointments.Where(a =>

            (string.IsNullOrWhiteSpace(searchText)
             || a.Patient.Contains(searchText,
                 StringComparison.OrdinalIgnoreCase)
             || a.MRN.Contains(searchText,
                 StringComparison.OrdinalIgnoreCase))

            &&

            (string.IsNullOrWhiteSpace(selectedType)
             || a.Type == selectedType)

            &&

            (string.IsNullOrWhiteSpace(selectedStatus)
             || a.Status == selectedStatus)
        );

    private string GetStatusClass(string status) => status switch
    {
        "Scheduled" => "scheduled",
        "Completed" => "completed",
        "Cancelled" => "cancelled",
        _ => ""
    };

    private void Schedule()
    {
        Nav.NavigateTo("/provider/schedule");
    }

    private void JoinConsult(AppointmentModel appt)
    {
        Nav.NavigateTo("/provider/videoconsult");
    }

    private void ViewAppointment(AppointmentModel appt)
    {
        Console.WriteLine($"Viewing appointment for {appt.Patient}");
    }

    public class AppointmentModel
    {
        public string Time { get; set; } = "";

        public string Patient { get; set; } = "";

        public string MRN { get; set; } = "";

        public string Provider { get; set; } = "";

        public string Type { get; set; } = "";

        public string Status { get; set; } = "";

        public string Reason { get; set; } = "";
    }
}