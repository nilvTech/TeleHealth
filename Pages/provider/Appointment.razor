@page "/provider/appointment"
@layout ProviderLayout
@inject NavigationManager Nav

<div class="appointment-container">

    <!-- HEADER -->
    <div class="header-section">

        <div>
            <h2 class="page-title">Appointments</h2>

            <p class="page-subtitle">
                Manage telehealth and in-person consultations
            </p>
        </div>

        <button class="btn-add"
                @onclick="Schedule">
            + Schedule Appointment
        </button>

    </div>

   

    <!-- FILTER BAR -->
    <div class="filter-bar">

        <!-- SEARCH -->
        <input class="search-box"
               placeholder="Search patient..."
               @bind="searchText" />

        <!-- TYPE -->
        <select class="filter-select"
                @bind="selectedType">

            <option value="">All Types</option>
            <option>Telehealth</option>
            <option>In-Person</option>

        </select>

        <!-- STATUS -->
        <select class="filter-select"
                @bind="selectedStatus">

            <option value="">All Status</option>
            <option>Scheduled</option>
            <option>Completed</option>
            <option>Cancelled</option>

        </select>

    </div>

    <!-- TABLE CARD -->
    <div class="table-card">

        <div class="card-header">

            <h3>Upcoming Appointments</h3>

            <span class="appointment-count">
                @FilteredAppointments.Count() Appointments
            </span>

        </div>

        <div class="table-wrapper">

            <table class="appointment-table">

                <thead>

                    <tr>

                        <th>Time</th>

                        <th>Patient</th>

                        <th>Provider</th>

                        <th>Type</th>

                        <th>Status</th>

                        <th>Reason</th>

                        <th>Action</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var appt in FilteredAppointments)
                    {
                        <tr>

                            <td>@appt.Time</td>

                            <td>

                                <div class="patient-cell">

                                    <div class="patient-name">
                                        @appt.Patient
                                    </div>

                                    <div class="patient-mrn">
                                        @appt.MRN
                                    </div>

                                </div>

                            </td>

                            <td>@appt.Provider</td>

                            <td>@appt.Type</td>

                            <td>

                                <span class="status-badge @GetStatusClass(appt.Status)">
                                    @appt.Status
                                </span>

                            </td>

                            <td>@appt.Reason</td>

                            <td>

                                <div class="action-row">

                                    <button class="btn-join"
                                            @onclick="() => JoinConsult(appt)">
                                        Join
                                    </button>

                                  

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@code {

    private string searchText = "";

    private string selectedType = "";

    private string selectedStatus = "";

    private List<AppointmentModel> appointments = new()
