@page "/provider/billing"

@inject NavigationManager Nav

<div class="billing-container">

    <!-- HEADER -->
    <div class="billing-header">

        <div>
            <h2>Billing & Claims</h2>

            <p class="sub-text">
                Manage claims, reimbursements and payment lifecycle
            </p>
        </div>

        <button class="btn-primary"
                @onclick="CreateClaim">
            + Create Claim
        </button>

    </div>

    <!-- CLAIMS -->
    <div class="card">

        <div class="card-header">
            <h3>Claims List</h3>
        </div>

        <table class="table">

            <thead>
                <tr>
                    <th>Claim ID</th>
                    <th>Patient</th>
                    <th>Provider</th>
                    <th>Payer</th>
                    <th>CPT</th>
                    <th>ICD</th>
                    <th>Claim Type</th>
                    <th>Priority</th>
                    <th>Minutes</th>
                    <th>Amount</th>
                    <th>Copay</th>
                    <th>Balance</th>
                    <th>Service Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var claim in claims)
                {
                    <tr>

                        <td>#@claim.ClaimId</td>

                        <td>@claim.Patient</td>

                        <td>@claim.Provider</td>

                        <td>@claim.Payer</td>

                        <td>
                            <span class="code-tag">
                                @claim.CPT
                            </span>
                        </td>

                        <td>@claim.ICD</td>

                        <td>@claim.ClaimType</td>

                        <td>
                            <span class="priority @GetPriorityClass(claim.Priority)">
                                @claim.Priority
                            </span>
                        </td>

                        <td>@claim.TimeSpent mins</td>

                        <td>$@claim.Amount</td>

                        <td>$@claim.Copay</td>

                        <td>$@claim.Balance</td>

                        <td>@claim.ServiceDate.ToShortDateString()</td>

                        <td>
                            <span class="status @GetStatusClass(claim.Status)">
                                @claim.Status
                            </span>
                        </td>

                        <td class="action-cell">

                            <div class="action-menu">

                                <button class="menu-btn"
                                        @onclick="() => ToggleMenu(claim)">
                                    ⋮
                                </button>

                                @if (claim.ShowMenu)
                                {
                                    <div class="menu-dropdown">

                                        @if (claim.Status != "Pending")
                                        {
                                            <button class="menu-item"
                                                    @onclick='() => UpdateStatus(claim, "Pending")'>
                                                <span>🕒</span>
                                                <span>Pending</span>
                                            </button>
                                        }

                                        @if (claim.Status != "Submitted")
                                        {
                                            <button class="menu-item"
                                                    @onclick='() => UpdateStatus(claim, "Submitted")'>
                                                <span>📤</span>
                                                <span>Submitted</span>
                                            </button>
                                        }

                                        @if (claim.Status != "In Process")
                                        {
                                            <button class="menu-item"
                                                    @onclick='() => UpdateStatus(claim, "In Process")'>
                                                <span>⚙</span>
                                                <span>In Process</span>
                                            </button>
                                        }

                                        @if (claim.Status != "Paid")
                                        {
                                            <button class="menu-item"
                                                    @onclick='() => UpdateStatus(claim, "Paid")'>
                                                <span>✔</span>
                                                <span>Paid</span>
                                            </button>
                                        }

                                        @if (claim.Status != "Denied")
                                        {
                                            <button class="menu-item"
                                                    @onclick='() => UpdateStatus(claim, "Denied")'>
                                                <span>✖</span>
                                                <span>Denied</span>
                                            </button>
                                        }

                                        <div class="menu-divider"></div>

                                        <button class="menu-item danger-item"
                                                @onclick='() => DeleteClaim(claim.ClaimId)'>
                                            <span>🗑</span>
                                            <span>Delete</span>
                                        </button>

                                    </div>
                                }

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

