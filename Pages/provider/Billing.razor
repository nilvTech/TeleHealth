    private void ToggleMenu(ClaimModel selectedClaim)
    {
        foreach (var claim in claims)
        {
            claim.ShowMenu = false;
        }

        selectedClaim.ShowMenu = true;
    }

    private void UpdateStatus(ClaimModel claim, string status)
    {
        claim.Status = status;
        claim.ShowMenu = false;
    }

    private void DeleteClaim(int claimId)
    {
        var claim = claims.FirstOrDefault(x => x.ClaimId == claimId);

        if (claim != null)
        {
            claims.Remove(claim);
        }
    }

    private void CreateClaim()
    {
        Nav.NavigateTo("/provider/createclaim");
    }

    private string GetStatusClass(string status) => status switch
    {
        "Pending" => "status-pending",
        "Submitted" => "status-submitted",
        "In Process" => "status-process",
        "Paid" => "status-paid",
        "Denied" => "status-denied",
        _ => ""
    };

    private string GetPriorityClass(string priority) => priority switch
    {
        "High" => "priority-high",
        "Medium" => "priority-medium",
        "Low" => "priority-low",
        _ => ""
    };

    public class ClaimModel
    {
        public int ClaimId { get; set; }

        public string Patient { get; set; } = "";

        public string Provider { get; set; } = "";

        public string Payer { get; set; } = "";

        public string CPT { get; set; } = "";

        public string ICD { get; set; } = "";

        public int TimeSpent { get; set; }

        public decimal Amount { get; set; }

        public decimal Copay { get; set; }

        public decimal Balance { get; set; }

        public string Status { get; set; } = "";

        public string ClaimType { get; set; } = "";

        public string Priority { get; set; } = "";

        public string AuthorizationNo { get; set; } = "";

        public string Facility { get; set; } = "";

        public string Notes { get; set; } = "";

        public DateTime ServiceDate { get; set; }

        public DateTime SubmittedDate { get; set; }

        public bool IsUrgent { get; set; }

        public bool ShowMenu { get; set; }
    }
