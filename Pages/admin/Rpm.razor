@page "/admin/rpm"
@layout AdminLayout

<h2 class="page-title">Remote Patient Monitoring</h2>

<div class="rpm-container">

    <!-- FILTERS -->
    <div class="filter-bar">


<h2 class="page-title">Remote Patient Monitoring - Admin Portal</h2>

<div class="rpm-container">

    <!-- TOP SUMMARY -->
    <div class="summary-grid">

        <div class="summary-card">
            <h5>Total RPM Patients</h5>
            <h2>1,248</h2>
            <span>+18 this week</span>
        </div>

        <div class="summary-card">
            <h5>Connected Devices</h5>
            <h2>2,964</h2>
            <span>96% Active</span>
        </div>

        <div class="summary-card">
            <h5>Critical Alerts</h5>
            <h2>34</h2>
            <span>Needs attention</span>
        </div>

        <div class="summary-card">
            <h5>Monthly Revenue</h5>
            <h2>$82,540</h2>
            <span>RPM Billing</span>
        </div>

    </div>

    <!-- DEVICE OVERVIEW -->
    <div class="card">

        <div class="card-header">
            <h3>Connected Device Overview</h3>
            <button class="btn-primary">Add Device</button>
        </div>

        <table class="styled-table">

            <thead>
                <tr>
                    <th>Device ID</th>
                    <th>Device Type</th>
                    <th>Assigned Patients</th>
                    <th>Status</th>
                    <th>Battery</th>
                    <th>Last Sync</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var d in Devices)
                {
                    <tr>

                        <td>@d.DeviceId</td>
                        <td>@d.DeviceType</td>
                        <td>@d.AssignedPatients</td>

                        <td>
                            <span class="status @d.Status.ToLower()">
                                @d.Status
                            </span>
                        </td>

                        <td>@d.Battery</td>

                        <td>@d.LastSync</td>

                        <td>

                            <div class="action-row">

                                <button class="btn-small">
                                    View
                                </button>

                                <button class="btn-small secondary">
                                    Edit
                                </button>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

    <!-- ALERTS -->
    <div class="card">

        <div class="card-header">
            <h3>Critical RPM Alerts</h3>
        </div>

        <div class="alert-list">

            @foreach (var alert in Alerts)
            {
                <div class="alert-item">

                    <div>
                        <h5>@alert.Patient</h5>
                        <span>@alert.Message</span>
                    </div>

                    <div class="alert-right">

                        <span class="priority @alert.Priority.ToLower()">
                            @alert.Priority
                        </span>

                        <button class="btn-primary">
                            Review
                        </button>

                    </div>

                </div>
            }

        </div>

    </div>

    <!-- PROVIDER PERFORMANCE -->
    <div class="card">

        <div class="card-header">
            <h3>Provider RPM Performance</h3>
        </div>

        <table class="styled-table">

            <thead>
                <tr>
                    <th>Provider</th>
                    <th>Patients</th>
                    <th>Monthly Readings</th>
                    <th>Critical Cases</th>
                    <th>Response Time</th>
                    <th>Performance</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var p in Providers)
                {
                    <tr>

                        <td>@p.Name</td>
                        <td>@p.Patients</td>
                        <td>@p.Readings</td>
                        <td>@p.CriticalCases</td>
                        <td>@p.ResponseTime</td>

                        <td>
                            <span class="performance">
                                @p.Performance
                            </span>
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

