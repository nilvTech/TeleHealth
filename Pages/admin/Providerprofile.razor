@page "/admin/providerprofile/{Id:int}"
@layout AdminLayout
@inject NavigationManager Nav

<div class="profile-container">

    <!-- HEADER -->
    <div class="profile-header">

        <div class="header-left">

            <div class="avatar-lg">
                @Provider.Name.Substring(0,2).ToUpper()
            </div>

            <div>
                <h2>@Provider.Name</h2>

                <div class="provider-meta">
                    <span>@Provider.Specialty</span>
                    <span>•</span>
                    <span>@Provider.ExperienceYears Years Experience</span>
                    <span>•</span>
                    <span>@Provider.Location</span>
                </div>
            </div>

        </div>

        <div class="header-actions">

            @if (!IsEditMode)
            {
                <button class="btn-primary"
                        @onclick="EnableEdit">
                    Edit Profile
                </button>
            }
            else
            {
                <button class="btn-success"
                        @onclick="SaveProfile">
                    Save
                </button>

                <button class="btn-secondary"
                        @onclick="CancelEdit">
                    Cancel
                </button>
            }

        </div>

    </div>

    <!-- KPI -->
    <div class="kpi-grid">

        <div class="kpi-card">
            <span>Total Patients</span>
            <h3>@Provider.TotalPatients</h3>
        </div>

        <div class="kpi-card">
            <span>Appointments</span>
            <h3>@Provider.TotalAppointments</h3>
        </div>

        <div class="kpi-card">
            <span>Consultation Fee</span>
            <h3>$@Provider.ConsultationFee</h3>
        </div>

        <div class="kpi-card">
            <span>Rating</span>
            <h3>@Provider.Rating ⭐</h3>
        </div>

    </div>

    <!-- PROFILE DETAILS -->
    <div class="profile-grid">

        <!-- LEFT -->
        <div class="card">

            <h3>Provider Information</h3>

            <div class="details-grid">

                <div class="field">
                    <label>Full Name</label>

                    @if (IsEditMode)
                    {
                        <input @bind="Provider.Name" />
                    }
                    else
                    {
                        <div class="value">@Provider.Name</div>
                    }
                </div>

                <div class="field">
                    <label>Email</label>

                    @if (IsEditMode)
                    {
                        <input @bind="Provider.Email" />
                    }
                    else
                    {
                        <div class="value">@Provider.Email</div>
                    }
                </div>

                <div class="field">
                    <label>Phone</label>

                    @if (IsEditMode)
                    {
                        <input @bind="Provider.Phone" />
                    }
                    else
                    {
                        <div class="value">@Provider.Phone</div>
                    }
                </div>

                <div class="field">
                    <label>Specialty</label>

                    @if (IsEditMode)
                    {
                        <input @bind="Provider.Specialty" />
                    }
                    else
                    {
                        <div class="value">@Provider.Specialty</div>
                    }
                </div>

                <div class="field">
                    <label>Experience</label>

                    @if (IsEditMode)
                    {
                        <input type="number"
                               @bind="Provider.ExperienceYears" />
                    }
                    else
                    {
                        <div class="value">@Provider.ExperienceYears Years</div>
                    }
                </div>

                <div class="field">
                    <label>License Status</label>

                    @if (IsEditMode)
                    {
                        <select @bind="Provider.LicenseStatus">
                            <option>Verified</option>
                            <option>Pending</option>
                        </select>
                    }
                    else
                    {
                        <div class="value">@Provider.LicenseStatus</div>
                    }
                </div>

                <div class="field">
                    <label>Status</label>

                    @if (IsEditMode)
                    {
                        <select @bind="Provider.Status">
                            <option>Active</option>
                            <option>Pending</option>
                            <option>Suspended</option>
                            <option>Rejected</option>
                        </select>
                    }
                    else
                    {
                        <div class="value">@Provider.Status</div>
                    }
                </div>

                <div class="field">
                    <label>Timezone</label>

                    @if (IsEditMode)
                    {
                        <input @bind="Provider.Timezone" />
                    }
                    else
                    {
                        <div class="value">@Provider.Timezone</div>
                    }
                </div>

                <div class="field full-width">
                    <label>Bio</label>

                    @if (IsEditMode)
                    {
                        <textarea rows="4"
                                  @bind="Provider.Bio"></textarea>
                    }
                    else
                    {
                        <div class="value">@Provider.Bio</div>
                    }
                </div>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="right-section">

            <!-- ADDRESS -->
            <div class="card">

                <h3>Address Information</h3>

                <div class="details-grid">

                    <div class="field">
                        <label>Address 1</label>

                        @if (IsEditMode)
                        {
                            <input @bind="Provider.Address1" />
                        }
                        else
                        {
                            <div class="value">@Provider.Address1</div>
                        }
                    </div>

                    <div class="field">
                        <label>Address 2</label>

                        @if (IsEditMode)
                        {
                            <input @bind="Provider.Address2" />
                        }
                        else
                        {
                            <div class="value">@Provider.Address2</div>
                        }
                    </div>

                    <div class="field">
                        <label>City</label>

                        @if (IsEditMode)
                        {
                            <input @bind="Provider.City" />
                        }
                        else
                        {
                            <div class="value">@Provider.City</div>
                        }
                    </div>

                    <div class="field">
                        <label>State</label>

                        @if (IsEditMode)
                        {
                            <input @bind="Provider.State" />
                        }
                        else
                        {
                            <div class="value">@Provider.State</div>
                        }
                    </div>

                    <div class="field">
                        <label>ZIP</label>

                        @if (IsEditMode)
                        {
                            <input @bind="Provider.Zip" />
                        }
                        else
                        {
                            <div class="value">@Provider.Zip</div>
                        }
                    </div>

                    <div class="field">
                        <label>Country</label>

                        @if (IsEditMode)
                        {
                            <input @bind="Provider.Country" />
                        }
                        else
                        {
                            <div class="value">@Provider.Country</div>
                        }
                    </div>

                </div>

            </div>

            <!-- EXTRA -->
            <div class="card">

                <h3>Professional Details</h3>

                <div class="info-row">
                    <span>Provider Group</span>
                    <b>@Provider.GroupName</b>
                </div>

                <div class="info-row">
                    <span>Website</span>
                    <b>@Provider.Website</b>
                </div>

                <div class="info-row">
                    <span>Primary Specialty</span>
                    <b>@Provider.Specialty1</b>
                </div>

                <div class="info-row">
                    <span>Secondary Specialty</span>
                    <b>@Provider.Specialty2</b>
                </div>

                <div class="info-row">
                    <span>Total Revenue</span>
                    <b>$@Provider.TotalRevenue</b>
                </div>

                <div class="info-row">
                    <span>Completed Visits</span>
                    <b>@Provider.CompletedVisits</b>
                </div>

            </div>

        </div>

    </div>

</div>

