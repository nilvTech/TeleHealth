@page "/admin/billing"
@layout AdminLayout
@inject NavigationManager Nav

<div class="billing-container">

    <!-- HEADER -->
    <div class="header-row">

        <h2 class="h2">Billing & Claims</h2>

        <button class="btn-primary"
                @onclick="CreateClaim">
            + Create Claim
        </button>

    </div>

    

    <!-- FILTERS -->

    <div class="filter-bar">

        <input class="search-box"
               placeholder="Search Patient, MRN, CPT..."
               @bind="SearchText" />

        <select @bind="SelectedStatus">
            <option value="">All Status</option>
            <option>Submitted</option>
            <option>Paid</option>
            <option>Rejected</option>
        </select>

        <select @bind="SelectedPayer">
            <option value="">All Payers</option>
            <option>Aetna</option>
            <option>Blue Cross</option>
            <option>Cigna</option>
            <option>United Healthcare</option>
        </select>

    </div>

    <!-- TABLE -->

    <div class="table-card">

        <table>

            <thead>

                <tr>
                    <th>Claim ID</th>
                    <th>Patient</th>
                    <th>MRN</th>
                    <th>CPT</th>
                    <th>ICD-10</th>
                    <th>Provider</th>
                    <th>Payer</th>
                    <th>DOS</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var c in FilteredClaims)
                {
                    <tr>

                        <td>#@c.Id</td>

                        <td>@c.PatientName</td>

                        <td>@c.MRN</td>

                        <td>@c.CPTCode</td>

                        <td>@c.ICD10</td>

                        <td>@c.ProviderName</td>

                        <td>@c.Payer</td>

                        <td>@c.DateOfService.ToString("MM/dd/yyyy")</td>

                        <td>$@c.Amount</td>

                        <td>
                            <span class="status @c.Status.ToLower()">
                                @c.Status
                            </span>
                        </td>

                        <td>

                            <div class="action-buttons">

                                <button class="btn-primary"
                                        @onclick="() => ViewDetails(c)">
                                    View
                                </button>

                                @if (c.Status == "Rejected")
                                {
                                    <button class="btn-secondary"
                                            @onclick="() => Resubmit(c)">
                                        Resubmit
                                    </button>
                                }

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>

