@page "/admin/roles"
@layout AdminLayout
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="role-container">

    <!-- HEADER -->
    <div class="header-row">

        <h2 class="h2">Role & Access Management</h2>

        <button class="btn-primary" @onclick="AddRole">
            + Add Role
        </button>

    </div>

    <!-- TABLE -->
    <div class="table-card">

        <table>

            <thead>
                <tr>
                    <th>Role Name</th>
                    <th>Description</th>
                    <th>Users</th>
                    <th>Created On</th>
                    <th>Last Updated</th>
                    <th>Status</th>
                    <th>Access Level</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var r in Role)
                {
                    <tr>
                        <td>@r.Name</td>
                        <td>@r.Description</td>
                        <td>@r.UserCount</td>
                        <td>@r.CreatedOn</td>
                        <td>@r.UpdatedOn</td>
                        <td><span class="status">@r.Status</span></td>
                        <td>@r.AccessLevel</td>

                        <td>
                            <button class="btn-secondary"
                                    @onclick="() => ToggleMatrix(r)">
                                Edit
                            </button>
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

    <!-- MATRIX -->
    @if (OpenRole != null)
    {
        <div class="matrix-card dropdown-panel"
             id="permissionMatrix">

            <h4>Permissions & Privileges - @OpenRole.Name</h4>

            <table class="matrix-table">

                <thead>
                    <tr>
                        <th>Module</th>
                        <th>View</th>
                        <th>Create</th>
                        <th>Edit</th>
                        <th>Delete</th>
                        <th>Export</th>
                        <th>Approve</th>
                        <th>Audit</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Permissions)
                    {
                        <tr>
                            <td>@p.Module</td>
                            <td><input type="checkbox" @bind="p.CanView" /></td>
                            <td><input type="checkbox" @bind="p.CanCreate" /></td>
                            <td><input type="checkbox" @bind="p.CanEdit" /></td>
                            <td><input type="checkbox" @bind="p.CanDelete" /></td>
                            <td><input type="checkbox" @bind="p.CanExport" /></td>
                            <td><input type="checkbox" @bind="p.CanApprove" /></td>
                            <td><input type="checkbox" @bind="p.CanAudit" /></td>
                        </tr>
                    }
                </tbody>

            </table>

            <div class="save-bar">

                <button class="btn-primary"
                        @onclick="() => SavePermissions(OpenRole)">
                    Save Changes
                </button>

                <button class="btn-secondary"
                        @onclick="Close">
                    Close
                </button>

            </div>

        </div>
    }

</div>

@code {

    RoleModel? OpenRole;

    void AddRole()
    {
        Nav.NavigateTo("/admin/addrole");
    }

    async Task ToggleMatrix(RoleModel r)
    {
        OpenRole = (OpenRole == r) ? null : r;

        StateHasChanged();

        await Task.Delay(100);
        await JS.InvokeVoidAsync("scrollToMatrix");
    }

    void Close()
    {
        OpenRole = null;
    }

    void SavePermissions(RoleModel r)
    {
        r.UpdatedOn = DateTime.Now.ToString("dd-MMM-yyyy");

        Console.WriteLine($"Saved permissions for {r.Name}");

        OpenRole = null;
    }

    class RoleModel
    {
        public string Name { get; set; }
        public string Description { get; set; }
        public int UserCount { get; set; }
        public string Status { get; set; }
        public string CreatedOn { get; set; }
        public string UpdatedOn { get; set; }
        public string AccessLevel { get; set; }
    }

    class PermissionModel
    {
        public string Module { get; set; }
        public bool CanView { get; set; }
        public bool CanCreate { get; set; }
        public bool CanEdit { get; set; }
        public bool CanDelete { get; set; }
        public bool CanExport { get; set; }
        public bool CanApprove { get; set; }
        public bool CanAudit { get; set; }
    }

    List<RoleModel> Role = new()
    {
        new() { Name="Super Admin", Description="Full system control", UserCount=2, Status="Active", CreatedOn="01-Jan-2025", UpdatedOn="10-Apr-2026", AccessLevel="Full" },
        new() { Name="Admin", Description="Manage users & system", UserCount=5, Status="Active", CreatedOn="05-Jan-2025", UpdatedOn="12-Apr-2026", AccessLevel="High" },
        new() { Name="Provider", Description="Doctor access", UserCount=20, Status="Active", CreatedOn="10-Jan-2025", UpdatedOn="15-Apr-2026", AccessLevel="Clinical" },
        new() { Name="Biller", Description="Claims & billing", UserCount=8, Status="Active", CreatedOn="15-Jan-2025", UpdatedOn="18-Apr-2026", AccessLevel="Finance" },
        new() { Name="Support Staff", Description="Patient support", UserCount=15, Status="Active", CreatedOn="20-Jan-2025", UpdatedOn="20-Apr-2026", AccessLevel="Limited" },
        new() { Name="Auditor", Description="Audit & compliance", UserCount=3, Status="Active", CreatedOn="01-Feb-2025", UpdatedOn="22-Apr-2026", AccessLevel="Audit" }
    };

    List<PermissionModel> Permissions = new()
    {
        new() { Module="Dashboard", CanView=true, CanCreate=false, CanEdit=false, CanDelete=false, CanExport=true, CanApprove=false, CanAudit=false },
        new() { Module="Patients", CanView=true, CanCreate=true, CanEdit=true, CanDelete=true, CanExport=true, CanApprove=true, CanAudit=false },
        new() { Module="Providers", CanView=true, CanEdit=true, CanApprove=true, CanExport=true },
        new() { Module="Appointments", CanView=true, CanCreate=true, CanEdit=true, CanDelete=false, CanExport=true, CanApprove=false, CanAudit=false },
        new() { Module="Billing & Claims", CanView=true, CanCreate=true, CanEdit=true, CanExport=true, CanDelete=true, CanApprove=true, CanAudit=true },
        new() { Module="Analytics", CanView=true, CanExport=true },
        new() { Module="Audit Logs", CanView=true, CanAudit=true, CanExport=true },
        new() { Module="Settings", CanView=true, CanEdit=true, CanExport=false }
    };
}