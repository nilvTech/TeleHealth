@page "/admin/roles"
@layout AdminLayout
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="role-container">

    <!-- HEADER -->
    <div class="header-row">

        <h2 class="h2">Role & Access Management</h2>

        <div class="header-actions">

            <button class="btn-primary" @onclick="AddRole">
                + Add Role
            </button>

        </div>

    </div>

    <!-- TABLE -->
    <div class="table-card">

        <table>

            <thead>
                <tr>
                    <th>Role Name</th>
                    <th>Description</th>
                    <th>Users</th>
                    <th>Created On</th>
                    <th>Last Updated</th>
                    <th>Status</th>
                    <th>Access Level</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var r in Role)
                {
                    <tr>
                        <td>@r.Name</td>
                        <td>@r.Description</td>
                        <td>@r.UserCount</td>
                        <td>@r.CreatedOn</td>
                        <td>@r.UpdatedOn</td>

                        <td>
                            <span class="status">@r.Status</span>
                        </td>

                        <td>@r.AccessLevel</td>

                        <td>
                            <div class="action-buttons">
                                <button class="btn-secondary" @onclick="() => EditRole(r)">
                                    Edit
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>

    <!-- PERMISSION MATRIX -->
    @if (SelectedRole != null)
    {
        <div class="matrix-card">

            <h4>Permissions - @SelectedRole.Name</h4>

            <table class="matrix-table">

                <thead>
                    <tr>
                        <th>Module</th>
                        <th>View</th>
                        <th>Create</th>
                        <th>Edit</th>
                        <th>Delete</th>
                        <th>Export</th>
                        <th>Approve</th>
                        <th>Audit</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Permissions)
                    {
                        <tr>
                            <td>@p.Module</td>
                            <td><input type="checkbox" @bind="p.CanView" /></td>
                            <td><input type="checkbox" @bind="p.CanCreate" /></td>
                            <td><input type="checkbox" @bind="p.CanEdit" /></td>
                            <td><input type="checkbox" @bind="p.CanDelete" /></td>
                            <td><input type="checkbox" @bind="p.CanExport" /></td>
                            <td><input type="checkbox" @bind="p.CanApprove" /></td>
                            <td><input type="checkbox" @bind="p.CanAudit" /></td>
                        </tr>
                    }
                </tbody>

            </table>

            <div class="save-bar">
                <button class="btn-primary" @onclick="SavePermissions">
                    Save Changes
                </button>
            </div>

        </div>
    }

</div>

@code {

    RoleModel? SelectedRole;

    class RoleModel
    {
        public string Name { get; set; }
        public string Description { get; set; }
        public int UserCount { get; set; }
        public string Status { get; set; }
        public string CreatedOn { get; set; }
        public string UpdatedOn { get; set; }
        public string AccessLevel { get; set; }
    }

    class PermissionModel
    {
        public string Module { get; set; }
        public bool CanView { get; set; }
        public bool CanCreate { get; set; }
        public bool CanEdit { get; set; }
        public bool CanDelete { get; set; }
        public bool CanExport { get; set; }
        public bool CanApprove { get; set; }
        public bool CanAudit { get; set; }
    }

    void AddRole()
    {
        Nav.NavigateTo("/admin/addrole");
    }

    void EditRole(RoleModel r)
    {
        SelectedRole = r;
    }

    void SavePermissions()
    {
        Console.WriteLine("Permissions Updated");
    }

    
    List<RoleModel> Role = new()
    {
        new() { Name="Super Admin", Description="Full system control", UserCount=2, Status="Active", CreatedOn="01-Jan-2025", UpdatedOn="10-Apr-2026", AccessLevel="Full" },
        new() { Name="Admin", Description="Manage users & system", UserCount=5, Status="Active", CreatedOn="05-Jan-2025", UpdatedOn="12-Apr-2026", AccessLevel="High" },
        new() { Name="Provider", Description="Doctor access", UserCount=20, Status="Active", CreatedOn="10-Jan-2025", UpdatedOn="15-Apr-2026", AccessLevel="Clinical" },
        new() { Name="Biller", Description="Claims & billing", UserCount=8, Status="Active", CreatedOn="15-Jan-2025", UpdatedOn="18-Apr-2026", AccessLevel="Finance" },
        new() { Name="Support Staff", Description="Patient support", UserCount=15, Status="Active", CreatedOn="20-Jan-2025", UpdatedOn="20-Apr-2026", AccessLevel="Limited" },
        new() { Name="Auditor", Description="Audit & compliance", UserCount=3, Status="Active", CreatedOn="01-Feb-2025", UpdatedOn="22-Apr-2026", AccessLevel="Audit" }
    };

    List<PermissionModel> Permissions = new()
    {
        new() { Module="Dashboard", CanView=true, CanExport=true },
        new() { Module="Patients", CanView=true, CanCreate=true, CanEdit=true, CanDelete=true },
        new() { Module="Providers", CanView=true, CanEdit=true, CanApprove=true },
        new() { Module="Appointments", CanView=true, CanCreate=true, CanEdit=true },
        new() { Module="Billing & Claims", CanView=true, CanCreate=true, CanEdit=true, CanExport=true },
        new() { Module="Analytics", CanView=true, CanExport=true },
        new() { Module="Audit Logs", CanView=true, CanAudit=true },
        new() { Module="Settings", CanView=true, CanEdit=true }
    };
}