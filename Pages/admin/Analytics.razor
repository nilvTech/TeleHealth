@page "/admin/analytics"
@layout AdminLayout

<div class="analytics-container">

    <!-- PAGE HEADER -->
    <div class="page-header">

        <div>
            <h2>Reports & Analytics</h2>
        </div>

        <div class="header-actions">

            <button class="btn-secondary">
                Export Excel
            </button>

            <button class="btn-primary">
                Export PDF
            </button>

        </div>

    </div>

    <!-- KPI CARDS -->

    <div class="summary-panel">

        <div class="summary-card">
            <div class="summary-label">Total Revenue</div>
            <div class="summary-value">$1,245,000</div>
            <div class="summary-sub">+14.2% this month</div>
        </div>

        <div class="summary-card">
            <div class="summary-label">Total Patients</div>
            <div class="summary-value">2,410</div>
            <div class="summary-sub">186 active today</div>
        </div>

        <div class="summary-card">
            <div class="summary-label">Claims Submitted</div>
            <div class="summary-value">860</div>
            <div class="summary-sub">92% approval rate</div>
        </div>

        <div class="summary-card">
            <div class="summary-label">Providers</div>
            <div class="summary-value">42</div>
            <div class="summary-sub">39 active</div>
        </div>

        <div class="summary-card">
            <div class="summary-label">RPM Devices</div>
            <div class="summary-value">1,180</div>
            <div class="summary-sub">96% connected</div>
        </div>

    </div>

    <!-- FILTERS -->

    <div class="filter-card">

        <input class="search-box"
               placeholder="Search report, provider, CPT..."
               @bind="SearchText" />

        <select @bind="SelectedPeriod">
            <option>Last 7 Days</option>
            <option>Last 30 Days</option>
            <option>Last 90 Days</option>
            <option>Last 12 Months</option>
        </select>

        <select @bind="SelectedProgram">
            <option>All Programs</option>
            <option>CCM</option>
            <option>RPM</option>
            <option>PCM</option>
            <option>BHI</option>
            <option>TCM</option>
        </select>

    </div>

    <!-- TABS -->

    <div class="tabs-wrapper">

        <div class="@Tab("revenue")"
             @onclick='() => ActiveTab="revenue"'>
            Revenue Analytics
        </div>

        <div class="@Tab("providers")"
             @onclick='() => ActiveTab="providers"'>
            Provider Performance
        </div>

        <div class="@Tab("patients")"
             @onclick='() => ActiveTab="patients"'>
            Patient Engagement
        </div>

        <div class="@Tab("claims")"
             @onclick='() => ActiveTab="claims"'>
            Claims Analytics
        </div>

        <div class="@Tab("forecast")"
             @onclick='() => ActiveTab="forecast"'>
            Financial Forecast
        </div>

    </div>

    <!-- REVENUE TAB -->

    @if (ActiveTab == "revenue")
    {
        <div class="table-card">

            <table>

                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Total Revenue</th>
                        <th>Insurance</th>
                        <th>Self Pay</th>
                        <th>Claims Paid</th>
                        <th>Avg Claim</th>
                        <th>Outstanding AR</th>
                        <th>AR Days</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var r in RevenueData)
                    {
                        <tr>
                            <td>@r.Date</td>
                            <td>$@r.Total.ToString("N0")</td>
                            <td>$@r.Insurance.ToString("N0")</td>
                            <td>$@r.SelfPay.ToString("N0")</td>
                            <td>@r.PaidClaims</td>
                            <td>$@r.AvgClaim</td>
                            <td>$@r.Outstanding.ToString("N0")</td>
                            <td>@r.ARDays</td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

    <!-- PROVIDERS TAB -->

    @if (ActiveTab == "providers")
    {
        <div class="table-card">

            <table>

                <thead>
                    <tr>
                        <th>Provider</th>
                        <th>Specialty</th>
                        <th>Visits</th>
                        <th>Patients</th>
                        <th>Revenue</th>
                        <th>Utilization</th>
                        <th>Rating</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var p in Providers)
                    {
                        <tr>

                            <td>@p.Name</td>
                            <td>@p.Specialty</td>
                            <td>@p.Visits</td>
                            <td>@p.Patients</td>
                            <td>$@p.Revenue.ToString("N0")</td>
                            <td>@p.Utilization%</td>
                            <td>@p.Rating</td>

                            <td>
                                <span class="status active">
                                    @p.Status
                                </span>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }
        <!-- PATIENTS TAB -->

    @if (ActiveTab == "patients")
    {
        <div class="table-card">

            <table>

                <thead>
                    <tr>
                        <th>Program Segment</th>
                        <th>Total Patients</th>
                        <th>Avg Visits</th>
                        <th>Chronic %</th>
                        <th>Retention %</th>
                        <th>No Show %</th>
                        <th>Revenue / Patient</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var p in PatientStats)
                    {
                        <tr>
                            <td>@p.Segment</td>
                            <td>@p.Total</td>
                            <td>@p.Visits</td>
                            <td>@p.Chronic%</td>
                            <td>@p.Retention%</td>
                            <td>@p.NoShow%</td>
                            <td>$@p.RevenuePerPatient</td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

    <!-- CLAIMS TAB -->

    @if (ActiveTab == "claims")
    {
        <div class="table-card">

            <table>

                <thead>
                    <tr>
                        <th>CPT Code</th>
                        <th>Description</th>
                        <th>Submitted</th>
                        <th>Paid</th>
                        <th>Rejected</th>
                        <th>Denial %</th>
                        <th>Avg Days</th>
                        <th>Revenue</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var c in Claims)
                    {
                        <tr>

                            <td>@c.CPT</td>
                            <td>@c.Description</td>
                            <td>@c.Submitted</td>
                            <td>@c.Paid</td>
                            <td>@c.Rejected</td>
                            <td>@c.Denial%</td>
                            <td>@c.Days</td>
                            <td>$@c.Amount.ToString("N0")</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

    <!-- FORECAST TAB -->

    @if (ActiveTab == "forecast")
    {
        <div class="table-card">

            <table>

                <thead>
                    <tr>
                        <th>Month</th>
                        <th>Projected Revenue</th>
                        <th>Visits</th>
                        <th>Growth %</th>
                        <th>Cost</th>
                        <th>Margin %</th>
                        <th>Risk Level</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var f in Forecast)
                    {
                        <tr>

                            <td>@f.Month</td>
                            <td>$@f.Revenue.ToString("N0")</td>
                            <td>@f.Visits</td>
                            <td>@f.Growth%</td>
                            <td>$@f.Cost.ToString("N0")</td>
                            <td>@f.Margin%</td>

                            <td>
                                <span class="risk @(f.Risk.ToLower())">
                                    @f.Risk
                                </span>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    }

</div>

