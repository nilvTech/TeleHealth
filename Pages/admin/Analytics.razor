@page "/admin/analytics"
@layout AdminLayout

<h2 class="h2">Reports and Analytics</h2>

<div class="actions-bar">

    <button class="btn-export">
        ⬇ Export Excel
    </button>

    <button class="btn-export">
        ⬇ Export PDF
    </button>

</div>
<div class="analytics-container">

    <!-- 🔹 TABS -->
    <div class="tabs-header">
        <div class="@Tab("revenue")" @onclick='() => ActiveTab="revenue"'>Revenue Analytics</div>
        <div class="@Tab("providers")" @onclick='() => ActiveTab="providers"'>Providers Performance </div>
        <div class="@Tab("patients")" @onclick='() => ActiveTab="patients"'>Patients Engagement</div>
        <div class="@Tab("claims")" @onclick='() => ActiveTab="claims"'>Claims Analytics</div>
        <div class="@Tab("forecast")" @onclick='() => ActiveTab="forecast"'>Financial Forecast</div>
    </div>

    <!-- 🔹 REVENUE -->
    @if (ActiveTab == "revenue")
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Insurance</th>
                        <th>Self Pay</th>
                        <th>Claims Paid</th>
                        <th>Avg Claim</th>
                        <th>Outstanding</th>
                        <th>AR Days</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in RevenueData)
                    {
                        <tr>
                            <td>@r.Date</td>
                            <td>$@r.Total</td>
                            <td>$@r.Insurance</td>
                            <td>$@r.SelfPay</td>
                            <td>@r.PaidClaims</td>
                            <td>$@r.AvgClaim</td>
                            <td>$@r.Outstanding</td>
                            <td>@r.ARDays</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- 🔹 PROVIDERS -->
    @if (ActiveTab == "providers")
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Specialty</th>
                        <th>Visits</th>
                        <th>Patients</th>
                        <th>Revenue</th>
                        <th>Utilization %</th>
                        <th>Rating</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Providers)
                    {
                        <tr>
                            <td>@p.Name</td>
                            <td>@p.Specialty</td>
                            <td>@p.Visits</td>
                            <td>@p.Patients</td>
                            <td>$@p.Revenue</td>
                            <td>@p.Utilization</td>
                            <td>@p.Rating</td>
                            <td>@p.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- 🔹 PATIENTS -->
    @if (ActiveTab == "patients")
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>Segment</th>
                        <th>Total</th>
                        <th>Visits</th>
                        <th>Chronic %</th>
                        <th>Retention %</th>
                        <th>No-show %</th>
                        <th>Revenue/Patient</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in PatientStats)
                    {
                        <tr>
                            <td>@p.Segment</td>
                            <td>@p.Total</td>
                            <td>@p.Visits</td>
                            <td>@p.Chronic</td>
                            <td>@p.Retention</td>
                            <td>@p.NoShow</td>
                            <td>$@p.RevenuePerPatient</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- 🔹 CLAIMS -->
    @if (ActiveTab == "claims")
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>CPT</th>
                        <th>Description</th>
                        <th>Submitted</th>
                        <th>Paid</th>
                        <th>Rejected</th>
                        <th>Denial %</th>
                        <th>Days</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Claims)
                    {
                        <tr>
                            <td>@c.CPT</td>
                            <td>@c.Description</td>
                            <td>@c.Submitted</td>
                            <td>@c.Paid</td>
                            <td>@c.Rejected</td>
                            <td>@c.Denial</td>
                            <td>@c.Days</td>
                            <td>$@c.Amount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- 🔹 FORECAST -->
    @if (ActiveTab == "forecast")
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>Month</th>
                        <th>Revenue</th>
                        <th>Visits</th>
                        <th>Growth %</th>
                        <th>Cost</th>
                        <th>Margin %</th>
                        <th>Risk</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Forecast)
                    {
                        <tr>
                            <td>@f.Month</td>
                            <td>$@f.Revenue</td>
                            <td>@f.Visits</td>
                            <td>@f.Growth</td>
                            <td>$@f.Cost</td>
                            <td>@f.Margin</td>
                            <td>@f.Risk</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

