@page "/admin/claimform"
@layout AdminLayout
@inject NavigationManager Nav

<div class="claim-container">

    <div class="page-header">

        <div>
            <h2>Create Claim</h2>
            <p>Create and submit insurance claims for reimbursement.</p>
        </div>

        <button class="btn-secondary"
                @onclick="BackToBilling">
            Back to Billing
        </button>

    </div>

    <!-- PATIENT INFORMATION -->

    <div class="card">

        <div class="card-title">
            Patient Information
        </div>

        <div class="form-grid">

            <div class="form-group">
                <label>Patient Name</label>
                <input @bind="Form.PatientName" />
            </div>

            <div class="form-group">
                <label>Date of Birth</label>
                <input type="date" @bind="Form.DOB" />
            </div>

            <div class="form-group">
                <label>Gender</label>
                <select @bind="Form.Gender">
                    <option>Male</option>
                    <option>Female</option>
                </select>
            </div>

            <div class="form-group">
                <label>Phone</label>
                <input @bind="Form.Phone" />
            </div>

            <div class="form-group full-width">
                <label>Address</label>
                <input @bind="Form.Address" />
            </div>

        </div>

    </div>

    <!-- INSURANCE -->

    <div class="card">

        <div class="card-title">
            Insurance Information
        </div>

        <div class="form-grid">

            <div class="form-group">
                <label>Insurance Plan</label>
                <input @bind="Form.InsurancePlan" />
            </div>

            <div class="form-group">
                <label>Policy Number</label>
                <input @bind="Form.PolicyNumber" />
            </div>

            <div class="form-group">
                <label>Insured Name</label>
                <input @bind="Form.InsuredName" />
            </div>

        </div>

    </div>

    <!-- CLAIM DETAILS -->

    <div class="card">

        <div class="card-title">
            Claim Details
        </div>

        <div class="form-grid">

            <div class="form-group">
                <label>Date of Illness</label>
                <input type="date" @bind="Form.IllnessDate" />
            </div>

            <div class="form-group">
                <label>Referring Provider</label>
                <input @bind="Form.RefProvider" />
            </div>

            <div class="form-group">
                <label>Diagnosis Code (ICD-10)</label>
                <input @bind="Form.Diagnosis" />
            </div>

        </div>

    </div>

    <!-- SERVICES -->

    <div class="card">

        <div class="services-header">

            <div class="card-title">
                Service Lines
            </div>

            <button class="btn-secondary"
                    @onclick="AddRow">
                + Add Service
            </button>

        </div>

        <div class="table-wrapper">

            <table>

                <thead>
                    <tr>
                        <th>Date</th>
                        <th>CPT Code</th>
                        <th>Description</th>
                        <th>Amount</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var s in Services)
                    {
                        <tr>

                            <td>
                                <input type="date"
                                       @bind="s.Date" />
                            </td>

                            <td>
                                <input @bind="s.CPT" />
                            </td>

                            <td>
                                <input @bind="s.Description" />
                            </td>

                            <td>
                                <input type="number"
                                       @bind="s.Amount" />
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- TOTAL -->

    <div class="card total-card">

        <div class="total-row">

            <span>Total Claim Amount</span>

            <strong>
                $@TotalAmount.ToString("N2")
            </strong>

        </div>

    </div>

    <!-- ACTIONS -->

    <div class="actions">

        <button class="btn-secondary"
                @onclick="BackToBilling">
            Cancel
        </button>

        <button class="btn-primary"
                @onclick="Submit">
            Submit Claim
        </button>

    </div>

</div>

@code {

    class ClaimForm
    {
        public string PatientName { get; set; } = "";
        public DateTime DOB { get; set; } = DateTime.Now;
        public string Gender { get; set; } = "Male";
        public string Phone { get; set; } = "";
        public string Address { get; set; } = "";

        public string InsurancePlan { get; set; } = "";
        public string PolicyNumber { get; set; } = "";
        public string InsuredName { get; set; } = "";

        public DateTime IllnessDate { get; set; } = DateTime.Now;
        public string RefProvider { get; set; } = "";
        public string Diagnosis { get; set; } = "";
    }

    class ServiceLine
    {
        public DateTime Date { get; set; } = DateTime.Now;
        public string CPT { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Amount { get; set; }
    }

    ClaimForm Form = new();

    List<ServiceLine> Services = new()
    {
        new()
        {
            CPT="99213",
            Description="Office Visit",
            Amount=120
        }
    };

    decimal TotalAmount =>
        Services.Sum(x => x.Amount);

    void AddRow()
    {
        Services.Add(new ServiceLine());
    }

    void Submit()
    {
        Nav.NavigateTo("/admin/billing");
    }

    void BackToBilling()
    {
        Nav.NavigateTo("/admin/billing");
    }
}