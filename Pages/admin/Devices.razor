@page "/admin/devices"
@layout AdminLayout
@inject NavigationManager Nav

<h2 class="page-title">Devices</h2>

<div class="devices-container">

    <!-- FILTERS -->
    <div class="filter-card">

        <div class="filter-row">

            <div class="filter-group">
                <label>Search Device</label>
                <input class="input"
                       placeholder="Search by device or patient..." />
            </div>

            <div class="filter-group">
                <label>Device Type</label>
                <select class="input">
                    <option>All Devices</option>
                    <option>Blood Pressure Monitor</option>
                    <option>Glucose Monitor</option>
                    <option>Pulse Oximeter</option>
                    <option>Weight Scale</option>
                    <option>Temperature Monitor</option>
                </select>
            </div>

            <div class="filter-group">
                <label>Status</label>
                <select class="input">
                    <option>All Status</option>
                    <option>Connected</option>
                    <option>Offline</option>
                    <option>Low Battery</option>
                </select>
            </div>

            <div class="filter-btn">
                <button class="btn-primary">
                    Search
                </button>
            </div>

        </div>

    </div>

    <!-- DEVICE TABLE -->
    <div class="card">

        <div class="card-header">

            <h3>Registered RPM Devices</h3>

            <div class="header-actions">

                <button class="btn-secondary">
                    Export
                </button>

                <button class="btn-primary" @onclick="AddDevices">
                     Add Device
                </button>

            </div>

        </div>

        <table class="styled-table">

            <thead>

                <tr>
                    <th>Device ID</th>
                    <th>Device Name</th>
                    <th>Device Type</th>
                    <th>Assigned Patient</th>
                    <th>Provider Group</th>
                    <th>Battery</th>
                    <th>Signal</th>
                    <th>Last Sync</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>

            </thead>

            <tbody>

                @foreach (var d in Device)
                {
                    <tr>

                        <td>@d.DeviceId</td>

                        <td>
                            <strong>@d.DeviceName</strong>
                        </td>

                        <td>@d.Type</td>

                        <td>@d.Patient</td>

                        <td>@d.ProviderGroup</td>

                        <td>@d.Battery</td>

                        <td>@d.Signal</td>

                        <td>@d.LastSync</td>

                        <td>
                            <span class="status @d.StatusClass">
                                @d.Status
                            </span>
                        </td>

                        <td>

                            <div class="action-row">

                                <button class="btn-small">
                                    View
                                </button>

                                <button class="btn-small secondary">
                                    Edit
                                </button>

                                <button class="btn-small danger">
                                    Disable
                                </button>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

    <!-- ALERTS -->
    <div class="card">

        <div class="card-header">
            <h3>System Device Alerts</h3>
        </div>

        <div class="alert-list">

            @foreach (var a in Alerts)
            {
                <div class="alert-item">

                    <div>

                        <h5>@a.Title</h5>

                        <p>@a.Description</p>

                    </div>

                    <span class="priority @a.Priority.ToLower()">
                        @a.Priority
                    </span>

                </div>
            }

        </div>

    </div>

</div>

@code {

