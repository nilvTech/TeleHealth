@page "/admin/addpatient"
@layout AdminLayout

<div class="add-patient-container">

    <div class="header">
        <h2>Add New Patient</h2>
       
    </div>

    <div class="form-card">

       

        <div class="form-grid">

            <div class="form-group">
                <label>First Name</label>
                <input />
            </div>

            <div class="form-group">
                <label>Last Name</label>
                <input />
            </div>

            <div class="form-group">
                <label>Date of Birth</label>
                <input type="date" />
            </div>

            <div class="form-group">
                <label>Gender</label>
                <select>
                    <option>Male</option>
                    <option>Female</option>
                </select>
            </div>

            <div class="form-group">
                <label>Phone</label>
                <input />
            </div>

            <div class="form-group">
                <label>Email</label>
                <input />
            </div>

        </div>

       

        <div class="form-grid">

            <div class="form-group">
                <label>Address Line 1</label>
                <input />
            </div>

            <div class="form-group">
                <label>City</label>
                <input />
            </div>

            <div class="form-group">
                <label>State</label>
                <input />
            </div>

            <div class="form-group">
                <label>ZIP</label>
                <input />
            </div>

            <div class="form-group">
                <label>Country</label>
                <input />
            </div>

        </div>

        

        <div class="form-grid">

            <div class="form-group">
                <label>Insurance</label>
                <input />
            </div>

            <div class="form-group">
                <label>Primary Provider</label>
                <input />
            </div>

            <div class="form-group">
                <label>Condition</label>
                <input />
            </div>

            <div class="form-group">
                <label>Risk Level</label>
                <select>
                    <option>Low</option>
                    <option>Medium</option>
                    <option>High</option>
                </select>
            </div>

        </div>
<br />
        <div class="actions">
            <button class="btn-secondary">Cancel</button>
            <button class="btn-primary">Save Patient</button>
        </div>

    </div>

</div>