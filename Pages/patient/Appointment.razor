@page "/patient/appointment"
@layout PatientLayout
@using Microsoft.AspNetCore.Components
@inject NavigationManager Nav

<div class="patient-container">

    <!-- HEADER -->
    <div class="header">

        <div>
            <h2>Appointments</h2>
            <div class="sub-text">Book and manage your consultations</div>
        </div>

    </div>

    <!-- BOOK APPOINTMENT -->
    <div class="card">

        <h4 class="section-title">Book Appointment</h4>

        <div class="form-grid">

            <div class="form-group">
                <label>Specialty</label>
                <select @bind="SelectedSpecialty" class="input">
                    <option>Cardiology</option>
                    <option>Dermatology</option>
                    <option>General Physician</option>
                </select>
            </div>

            <div class="form-group">
                <label>Doctor</label>
                <select @bind="SelectedDoctor" class="input">
                    <option>Dr. John Smith (Cardiology)</option>
                    <option>Dr. Emily Brown (Dermatology)</option>
                    <option>Dr. Alex Carter (General Physician)</option>
                </select>
            </div>

            <div class="form-group">
                <label>Date</label>
                <input type="date" @bind="SelectedDate" class="input" />
            </div>

            <div class="form-group">
                <label>Time</label>
                <input type="time" @bind="SelectedTime" class="input" />
            </div>

            <div class="form-group full">
                <label>Patient Notes</label>
                <textarea class="input textarea"
                          @bind="PatientNotes"
                          placeholder="Describe symptoms, allergies, history..."></textarea>
            </div>

        </div>
<br>
        <div class="btn-row">
            <button class="btn-primary" @onclick="OpenConfirmModal">
                Confirm Appointment
            </button>
        </div>

    </div>

    <!-- LATEST APPOINTMENT -->
    <div class="card">

        <h4 class="section-title">Latest Appointment Details</h4>

        <div class="details-grid">

            <div class="detail-item">
                <span class="label">Doctor</span>
                <span class="value">@SelectedDoctor</span>
            </div>

            <div class="detail-item">
                <span class="label">Specialty</span>
                <span class="value">@SelectedSpecialty</span>
            </div>

            <div class="detail-item">
                <span class="label">Date</span>
                <span class="value">@SelectedDate.ToString("dd MMM yyyy")</span>
            </div>

            <div class="detail-item">
                <span class="label">Time</span>
                <span class="value">@SelectedTime.ToString("hh\\:mm")</span>
            </div>

        </div>

        <div class="notes-box">
            <span class="label">Notes</span>
            <p>@PatientNotes</p>
        </div>

    </div>

    <!-- MY APPOINTMENTS -->
    <div class="table-card">

        <h4 class="section-title">My Appointments</h4>

        <table class="patient-table">

            <thead>
                <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Doctor</th>
                    <th>Provider Group</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var a in MyAppointments)
                {
                    <tr>

                        <td>@a.Date.ToString("dd MMM yyyy")</td>
                        <td>@a.Time</td>
                        <td class="patient-name">@a.Doctor</td>
                        <td>@a.Group</td>

                        <td>
                            <span class="status-badge @a.Status.ToLower()">
                                @a.Status
                            </span>
                        </td>

                        <td>
                            <div class="action-cell">

                                @if (a.Status == "Upcoming")
                                {
                                    <button class="btn-join"
                                            @onclick="() => JoinConsult(a)">
                                        Join
                                    </button>

                                    <button class="btn-cancel"
                                            @onclick="() => CancelAppointment(a)">
                                        Cancel
                                    </button>
                                }
                                else
                                {
                                    <span class="action-empty">-</span>
                                }

                            </div>
                        </td>

                    </tr>
                }
            </tbody>

        </table>

    </div>

</div>

<!-- MODAL -->
@if (ShowConfirmModal)
{
    <div class="modal-overlay">

        <div class="modal-box">

            @if (!ShowSuccess)
            {
                <h3>Confirm Appointment</h3>

                <div class="modal-content">

                    <p><b>Doctor:</b> @PendingAppointment?.Doctor</p>
                    <p><b>Specialty:</b> @SelectedSpecialty</p>
                    <p><b>Date:</b> @PendingAppointment?.Date.ToString("dd MMM yyyy")</p>
                    <p><b>Time:</b> @PendingAppointment?.Time</p>
                    <p><b>Group:</b> @PendingAppointment?.Group</p>

                </div>

                <div class="modal-actions">

                    <button class="btn-cancel" @onclick="CloseModal">
                        Cancel
                    </button>

                    <button class="btn-join" @onclick="ConfirmFromModal">
                        Confirm
                    </button>

                </div>
            }
            else
            {
                <div class="modal-success">

                    <div class="success-icon">✅</div>

                    <h3>Appointment Confirmed</h3>

                    <p>
                        Your appointment with
                        <b>@PendingAppointment?.Doctor</b>
                        has been booked successfully.
                    </p>

                </div>
            }

        </div>

    </div>
}

@code {

    bool ShowConfirmModal = false;
    bool ShowSuccess = false;

    AppointmentModel PendingAppointment;

    DateTime SelectedDate = DateTime.Today;
    TimeOnly SelectedTime = TimeOnly.FromDateTime(DateTime.Now);

    string SelectedDoctor = "Dr. John Smith (Cardiology)";
    string SelectedSpecialty = "Cardiology";
    string PatientNotes = "";

    class AppointmentModel
    {
        public DateTime Date { get; set; }
        public string Time { get; set; }
        public string Doctor { get; set; }
        public string Group { get; set; }
        public string Status { get; set; }
    }

    List<AppointmentModel> MyAppointments = new()
    {
        new()
        {
            Date = DateTime.Today.AddDays(1),
            Time = "10:00 AM",
            Doctor = "Dr. John Smith",
            Group = "Heart Care Group",
            Status = "Upcoming"
        },
        new()
        {
            Date = DateTime.Today.AddDays(2),
            Time = "12:30 PM",
            Doctor = "Dr. Emily Brown",
            Group = "Skin Clinic Group",
            Status = "Upcoming"
        },
        new()
        {
            Date = DateTime.Today.AddDays(-2),
            Time = "02:00 PM",
            Doctor = "Dr. Alex Carter",
            Group = "General Health Group",
            Status = "Completed"
        }
    };

    void OpenConfirmModal()
    {
        PendingAppointment = new AppointmentModel
        {
            Date = SelectedDate,
            Time = SelectedTime.ToString("hh\\:mm"),
            Doctor = SelectedDoctor,
            Group = "TeleHealth Medical Group",
            Status = "Upcoming"
        };

        ShowConfirmModal = true;
        ShowSuccess = false;
    }

    async Task ConfirmFromModal()
    {
        MyAppointments.Insert(0, PendingAppointment);

        ShowSuccess = true;

        StateHasChanged();

        await Task.Delay(1500);

        ShowConfirmModal = false;
        ShowSuccess = false;
        PendingAppointment = null;
    }

    void CloseModal()
    {
        ShowConfirmModal = false;
        ShowSuccess = false;
        PendingAppointment = null;
    }

    private void JoinConsult(AppointmentModel a)
    {
        Nav.NavigateTo("/patient/videoconsultation");
    }

    private void CancelAppointment(AppointmentModel a)
    {
        a.Status = "Cancelled";
    }
}