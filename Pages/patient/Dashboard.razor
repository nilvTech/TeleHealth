@page "/patient/dashboard"
@layout PatientLayout

<div class="patient-container">

    <!-- HEADER -->
    <div class="header">
            <div class="h2">Welcome back, Sarah Johnson</div>
    </div>

    <!-- GRID -->
    <div class="dashboard-grid">

        <!-- LEFT -->
        <div>

            <!-- UPCOMING APPOINTMENT -->
            <div class="card">
                <h4>Upcoming Appointment</h4>

                <div class="info-block">
                    <p><b>Doctor:</b> Dr. Michael Smith (Cardiology)</p>
                    <p><b>Date:</b> 10 May 2026</p>
                    <p><b>Time:</b> 10:30 AM</p>
                    <p><b>Type:</b> Teleconsultation</p>
                    <p><b>Status:</b> Confirmed</p>
                </div>

                <button class="btn-add">Join Call</button>
            </div>

            <!-- HEALTH SUMMARY -->
            <div class="card">
                <h4>Health Summary</h4>

                <div class="health-grid">

                    <div class="health-box">
                        <div class="label">Blood Pressure</div>
                        <div class="value">130/85</div>
                    </div>

                    <div class="health-box">
                        <div class="label">Heart Rate</div>
                        <div class="value">78 bpm</div>
                    </div>

                    <div class="health-box">
                        <div class="label">Blood Sugar</div>
                        <div class="value">140 mg/dL</div>
                    </div>

                    <div class="health-box">
                        <div class="label">BMI</div>
                        <div class="value">24.5</div>
                    </div>

                </div>
            </div>

            <!-- RECENT VISITS -->
            <div class="table-card">
                <table class="patient-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Doctor</th>
                            <th>Type</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var v in Visits)
                        {
                            <tr>
                                <td>@v.Date</td>
                                <td class="patient-name">@v.Doctor</td>
                                <td>@v.Type</td>
                                <td>@v.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>

        <!-- RIGHT -->
        <div>

            <!-- QUICK ACTIONS (RESTORED LINK STYLE) -->
            <div class="card">
                <h4>Quick Actions</h4>

                <div class="quick-links">
                    <a href="patient/appointment">+ Book Appointment</a>
                    <a href="patient/orders?tab=records">📄 View Medical Records</a>
                    <a href="patient/orders?tab=prescriptions">💊 Order Medication</a>
                    <a href="patient/billing">💳 View Billing</a>
                </div>
            </div>

            <!-- NOTIFICATIONS -->
            <div class="card">
                <h4>Notifications</h4>

                <div class="notification-list">
                    <div>🔔 Appointment confirmed for 10 May</div>
                    <div>💊 Prescription ready for pickup</div>
                    <div>📄 Lab report uploaded</div>
                </div>
            </div>

            <!-- BILLING -->
            <div class="card">
                <h4>Billing Summary</h4>

                <div class="info-block">
                    <p><b>Total Due:</b> $120</p>
                    <p><b>Last Payment:</b> $80 (Paid)</p>
                    <p><b>Insurance:</b> Aetna</p>
                </div>

                <a class="link" href="#">View Details →</a>
            </div>

        </div>

    </div>
</div>

@code {

    class Visit
    {
        public string Date { get; set; }
        public string Doctor { get; set; }
        public string Type { get; set; }
        public string Status { get; set; }
    }

    List<Visit> Visits = new()
    {
        new Visit { Date="05 May", Doctor="Dr. Lee", Type="Tele", Status="Completed" },
        new Visit { Date="28 Apr", Doctor="Dr. Brown", Type="In-person", Status="Completed" },
        new Visit { Date="20 Apr", Doctor="Dr. Smith", Type="Tele", Status="Completed" }
    };
}