@page "/patient/messages"
@layout PatientLayout

<div class="message-container">

    <!-- HEADER -->
    <div class="message-header">
        <div>
            <h2 class="page-title">Messages</h2>
            <p class="page-subtitle">Secure communication with care team</p>
        </div>

        <button class="btn-primary" @onclick="OpenCompose">
            + New Message
        </button>
    </div>

    <!-- STATS -->
    <div class="stats-row">

        <div class="stat-card">
            <h5>Total</h5>
            <h3>@Messages.Count</h3>
        </div>

        <div class="stat-card">
            <h5>Unread</h5>
            <h3>@Messages.Count(x => !x.IsRead)</h3>
        </div>

        <div class="stat-card">
            <h5>Archived</h5>
            <h3>@Messages.Count(x => x.Type == "Archived")</h3>
        </div>

        <div class="stat-card">
            <h5>Sent</h5>
            <h3>@Messages.Count(x => x.Type == "Sent")</h3>
        </div>

    </div>

    <!-- MAIN -->
    <div class="message-grid">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <div class="@GetSidebarClass("Inbox")" @onclick='() => ChangeFolder("Inbox")'>
                Inbox <span>@Messages.Count(x => x.Type=="Inbox")</span>
            </div>

            <div class="@GetSidebarClass("Sent")" @onclick='() => ChangeFolder("Sent")'>
                Sent <span>@Messages.Count(x => x.Type=="Sent")</span>
            </div>

            <div class="@GetSidebarClass("Draft")" @onclick='() => ChangeFolder("Draft")'>
                Drafts <span>@Messages.Count(x => x.Type=="Draft")</span>
            </div>

            <div class="@GetSidebarClass("Archived")" @onclick='() => ChangeFolder("Archived")'>
                Archived <span>@Messages.Count(x => x.Type=="Archived")</span>
            </div>

        </div>

        <!-- LIST -->
        <div class="message-list-card">

            <div class="toolbar">
                <input class="search-box" placeholder="Search messages..." @bind="SearchText" />

                <select class="filter-select" @bind="SelectedFilter">
                    <option value="All">All</option>
                    <option value="Unread">Unread</option>
                    <option value="Read">Read</option>
                </select>
            </div>

            <div class="message-list">

                @foreach (var msg in FilteredMessages)
                {
                    <div class="message-item @(SelectedMessage == msg ? "active" : "")"
                         @onclick="() => OpenMessage(msg)">

                        <div class="message-top">
                            <div>
                                <h4>@msg.Provider</h4>
                                <p>@msg.Subject</p>
                            </div>

                            <div class="msg-meta">
                                <span class="time">@msg.Time</span>

                                @if (!msg.IsRead)
                                {
                                    <span class="unread-dot"></span>
                                }
                            </div>
                        </div>

                        <div class="message-preview">
                            @msg.Preview
                        </div>

                    </div>
                }

            </div>

        </div>

        <!-- DETAILS -->
        <div class="details-card">

            @if (IsCompose)
            {
                <div class="compose-box">
                    <h3>Compose</h3>

                    <input class="input" placeholder="Provider" @bind="ComposeProvider" />
                    <input class="input" placeholder="Subject" @bind="ComposeSubject" />

                    <textarea class="textarea" placeholder="Message..." @bind="ComposeBody"></textarea>

                    <div class="actions">
                        <button class="btn-secondary" @onclick="CancelCompose">Cancel</button>
                        <button class="btn-primary" @onclick="SendNewMessage">Send</button>
                    </div>
                </div>
            }
            else if (SelectedMessage != null)
            {
                <div class="details-header">
                    <div>
                        <h3>@SelectedMessage.Subject</h3>
                        <p>@SelectedMessage.Provider</p>
                    </div>

                    <span class="date">@SelectedMessage.Date</span>
                </div>

                <div class="message-body">
                    @SelectedMessage.Content
                </div>

                <div class="actions">
                    <button class="btn-secondary" @onclick="ToggleRead">
                        @(SelectedMessage.IsRead ? "Mark Unread" : "Mark Read")
                    </button>

                    <button class="btn-secondary" @onclick="ArchiveMessage">Archive</button>
                    <button class="btn-danger" @onclick="DeleteMessage">Delete</button>
                </div>

                <textarea class="textarea" placeholder="Reply..." @bind="ReplyText"></textarea>

                <div class="actions">
                    <button class="btn-primary" @onclick="SendReply">Send Reply</button>
                </div>
            }
            else
            {
                <div class="empty">
                    Select a message
                </div>
            }

        </div>

    </div>

</div>

@code {
    string CurrentFolder = "Inbox";
    string SearchText = "";
    string SelectedFilter = "All";

    bool IsCompose = false;

    string ComposeProvider = "";
    string ComposeSubject = "";
    string ComposeBody = "";
    string ReplyText = "";

    MessageModel? SelectedMessage;

    class MessageModel
    {
        public string Provider { get; set; }
        public string Subject { get; set; }
        public string Preview { get; set; }
        public string Content { get; set; }
        public string Time { get; set; }
        public string Date { get; set; }
        public bool IsRead { get; set; }
        public string Type { get; set; }
    }

    List<MessageModel> Messages = new()
    {
        new() { Provider="Dr. Brown", Subject="Follow-up", Preview="Continue meds...", Content="Continue meds for 2 weeks", Time="10:30", Date="Today", IsRead=false, Type="Inbox" },
        new() { Provider="Billing", Subject="Invoice", Preview="Invoice ready...", Content="Invoice generated", Time="Yesterday", Date="May 5", IsRead=true, Type="Inbox" }
    };

    IEnumerable<MessageModel> FilteredMessages =>
        Messages.Where(x => x.Type == CurrentFolder);

    void OpenMessage(MessageModel msg)
    {
        SelectedMessage = msg;
        msg.IsRead = true;
        IsCompose = false;
    }

    void ChangeFolder(string folder)
    {
        CurrentFolder = folder;
        SelectedMessage = null;
    }

    string GetSidebarClass(string folder)
        => CurrentFolder == folder ? "sidebar-item active" : "sidebar-item";

    void OpenCompose() => IsCompose = true;
    void CancelCompose() => IsCompose = false;

    void SendNewMessage()
    {
        Messages.Insert(0, new MessageModel
        {
            Provider = ComposeProvider,
            Subject = ComposeSubject,
            Preview = ComposeBody,
            Content = ComposeBody,
            Time = DateTime.Now.ToShortTimeString(),
            Date = DateTime.Today.ToShortDateString(),
            IsRead = true,
            Type = "Sent"
        });

        IsCompose = false;
    }

    void SendReply() => ReplyText = "";

    void ToggleRead()
    {
        if (SelectedMessage != null)
            SelectedMessage.IsRead = !SelectedMessage.IsRead;
    }

    void ArchiveMessage()
    {
        if (SelectedMessage != null)
            SelectedMessage.Type = "Archived";
    }

    void DeleteMessage()
    {
        if (SelectedMessage != null)
            Messages.Remove(SelectedMessage);
    }
}