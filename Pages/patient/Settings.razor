@page "/patient/settings"
@layout PatientLayout

<h2 class="page-title">Settings</h2>

<div class="settings-container">

    <!-- HEADER -->
    <div class="settings-header">

        <div class="header-left">
            <div class="avatar">SJ</div>

            <div>
                <h3>Sarah Johnson</h3>
                <p>Patient Preferences & Account Settings</p>
            </div>
        </div>

        @if (!IsEditMode)
        {
            <button class="btn-update" @onclick="EnableEdit">
                Update Settings
            </button>
        }
        else
        {
            <button class="btn-save" @onclick="SaveSettings">
                Save Settings
            </button>
        }

    </div>

    <!-- SETTINGS GRID -->
    <div class="settings-grid">

        <!-- LEFT -->
        <div>

            <!-- NOTIFICATIONS -->
            <div class="card">

                <div class="card-header">
                    <h3>Notifications</h3>
                </div>

                <div class="setting-list">

                    <div class="setting-item">
                        <div>
                            <h4>Email Notifications</h4>
                            <p>Receive appointment and billing alerts</p>
                        </div>

                        <input type="checkbox"
                               @bind="EmailNotifications"
                               disabled="@(!IsEditMode)" />
                    </div>

                    <div class="setting-item">
                        <div>
                            <h4>SMS Notifications</h4>
                            <p>Receive appointment reminders via SMS</p>
                        </div>

                        <input type="checkbox"
                               @bind="SmsNotifications"
                               disabled="@(!IsEditMode)" />
                    </div>

                    <div class="setting-item">
                        <div>
                            <h4>Medication Alerts</h4>
                            <p>Daily medication reminder alerts</p>
                        </div>

                        <input type="checkbox"
                               @bind="MedicationAlerts"
                               disabled="@(!IsEditMode)" />
                    </div>

                    <div class="setting-item">
                        <div>
                            <h4>Care Plan Updates</h4>
                            <p>Receive updates from care coordinators</p>
                        </div>

                        <input type="checkbox"
                               @bind="CarePlanUpdates"
                               disabled="@(!IsEditMode)" />
                    </div>

                </div>

            </div>

            <!-- PRIVACY -->
            <div class="card">

                <div class="card-header">
                    <h3>Privacy & Security</h3>
                </div>

                <div class="form-grid">

                    <div class="form-group">
                        <label>Two Factor Authentication</label>

                        <select class="input"
                                @bind="TwoFactor"
                                disabled="@(!IsEditMode)">
                            <option>Enabled</option>
                            <option>Disabled</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Session Timeout</label>

                        <select class="input"
                                @bind="SessionTimeout"
                                disabled="@(!IsEditMode)">
                            <option>15 Minutes</option>
                            <option>30 Minutes</option>
                            <option>60 Minutes</option>
                        </select>
                    </div>

                    <div class="form-group full">
                        <label>Authorized Caregiver Access</label>

                        <textarea class="input textarea"
                                  disabled="@(!IsEditMode)"
                                  @bind="CaregiverAccess">
                        </textarea>
                    </div>

                </div>

            </div>

        </div>

        <!-- RIGHT -->
        <div>

            <!-- TELEHEALTH -->
            <div class="card">

                <div class="card-header">
                    <h3>Telehealth Preferences</h3>
                </div>

                <div class="form-grid single">

                    <div class="form-group">
                        <label>Preferred Video Quality</label>

                        <select class="input"
                                @bind="VideoQuality"
                                disabled="@(!IsEditMode)">
                            <option>720p HD</option>
                            <option>1080p Full HD</option>
                            <option>480p SD</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Preferred Language</label>

                        <select class="input"
                                @bind="PreferredLanguage"
                                disabled="@(!IsEditMode)">
                            <option>English</option>
                            <option>Spanish</option>
                            <option>French</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Communication Preference</label>

                        <select class="input"
                                @bind="CommunicationPreference"
                                disabled="@(!IsEditMode)">
                            <option>Video Call</option>
                            <option>Phone Call</option>
                            <option>Chat Only</option>
                        </select>
                    </div>

                </div>

            </div>

            <!-- DEVICES -->
            <div class="card">

                <div class="card-header">
                    <h3>Connected Devices</h3>
                </div>

                <div class="device-list">

                    @foreach (var device in Devices)
                    {
                        <div class="device-item">

                            <div>
                                <h4>@device.Name</h4>
                                <p>@device.LastSync</p>
                            </div>

                            <span class="device-status">
                                @device.Status
                            </span>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>

@code {

    bool IsEditMode = false;

    bool EmailNotifications = true;
    bool SmsNotifications = true;
    bool MedicationAlerts = true;
    bool CarePlanUpdates = false;

    string TwoFactor = "Enabled";
    string SessionTimeout = "30 Minutes";

    string CaregiverAccess =
        "Michael Johnson (Spouse) has authorized caregiver access.";

    string VideoQuality = "720p HD";
    string PreferredLanguage = "English";
    string CommunicationPreference = "Video Call";

    class DeviceModel
    {
        public string Name { get; set; }
        public string LastSync { get; set; }
        public string Status { get; set; }
    }

    List<DeviceModel> Devices = new()
    {
        new()
        {
            Name = "Apple Watch Series 9",
            LastSync = "Last synced 10 mins ago",
            Status = "Connected"
        },

        new()
        {
            Name = "Blood Pressure Monitor",
            LastSync = "Last synced 1 hour ago",
            Status = "Connected"
        },

        new()
        {
            Name = "Fitbit Charge 6",
            LastSync = "Last synced yesterday",
            Status = "Inactive"
        }
    };

    void EnableEdit()
    {
        IsEditMode = true;
    }

    void SaveSettings()
    {
        IsEditMode = false;
    }
}