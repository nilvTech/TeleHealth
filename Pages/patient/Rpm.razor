@page "/patient/rpm"
@layout PatientLayout

<div class="rpm-container">

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div>
            <h2 class="page-title">Remote Patient Monitoring</h2>
            <p class="page-subtitle">Live health tracking, device sync, and care insights</p>
        </div>

        <button class="btn-primary">
            Sync Devices
        </button>
    </div>

    <!-- SUMMARY -->
    <div class="metrics-grid">

        <div class="summary-card">
            <h5>Today's Readings</h5>
            <h2>6</h2>
            <span>Synced Successfully</span>
        </div>

        <div class="summary-card">
            <h5>Connected Devices</h5>
            <h2>4</h2>
            <span>All Active</span>
        </div>

        <div class="summary-card">
            <h5>Health Score</h5>
            <h2>92%</h2>
            <span>Excellent Condition</span>
        </div>

        <div class="summary-card">
            <h5>Care Alerts</h5>
            <h2>2</h2>
            <span>Pending Review</span>
        </div>

    </div>
    
 <!-- METRICS -->
    <div class="metrics-grid">

        <div class="metric-card">
            <h4>Blood Pressure</h4>
            <div class="metric-value">124/82</div>
            <span class="metric-badge good">Stable</span>
        </div>

        <div class="metric-card">
            <h4>Heart Rate</h4>
            <div class="metric-value">78 bpm</div>
            <span class="metric-badge good">Normal</span>
        </div>

        <div class="metric-card">
            <h4>Blood Sugar</h4>
            <div class="metric-value">108 mg/dL</div>
            <span class="metric-badge good">Controlled</span>
        </div>

        <div class="metric-card">
            <h4>Weight</h4>
            <div class="metric-value">72 kg</div>
            <span class="metric-badge good">Healthy</span>
        </div>

    </div>
    <!-- LIVE READINGS -->
    <div class="card">

        <div class="card-header">
            <h3>Live Device Readings</h3>
        </div>

        <table class="styled-table">
            <thead>
                <tr>
                    <th>Device</th>
                    <th>Reading</th>
                    <th>Range</th>
                    <th>Status</th>
                    <th>Updated</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var d in Readings)
                {
                    <tr>
                        <td>
                            <div class="device-cell">
                                <div class="device-icon">@d.Icon</div>
                                <div>
                                    <div class="device-name">@d.Device</div>
                                    <div class="device-type">@d.Type</div>
                                </div>
                            </div>
                        </td>

                        <td class="strong">@d.Reading</td>
                        <td>@d.Range</td>

                        <td>
                            <span class="status @d.Status.ToLower()">@d.Status</span>
                        </td>

                        <td>@d.Updated</td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

   

    <!-- ALERTS -->
    <div class="card">

        <div class="card-header">
            <h3>Care Team Notifications</h3>
        </div>

        <div class="alert-list">

            @foreach (var a in Alerts)
            {
                <div class="alert-item">

                    <div>
                        <h5>@a.Title</h5>
                        <p>@a.Message</p>
                    </div>

                    <span class="priority @a.Priority.ToLower()">
                        @a.Priority
                    </span>

                </div>
            }

        </div>

    </div>

    <!-- DEVICES -->
    <div class="card">

        <div class="card-header">
            <h3>Connected Devices</h3>
        </div>

        <div class="device-grid">

            @foreach (var d in Devices)
            {
                <div class="device-card">

                    <div class="device-top">
                        <div class="device-big-icon">@d.Icon</div>
                        <span class="status @d.Status.ToLower()">@d.Status</span>
                    </div>

                    <h4>@d.Name</h4>
                    <p>@d.Type</p>

                    <div class="device-meta">
                        <div>
                            <label>Battery</label>
                            <strong>@d.Battery</strong>
                        </div>

                        <div>
                            <label>Sync</label>
                            <strong>@d.Sync</strong>
                        </div>
                    </div>

                   
                </div>
            }

        </div>

    </div>

</div>

@code {

    class ReadingModel
    {
        public string Icon { get; set; }
        public string Device { get; set; }
        public string Type { get; set; }
        public string Reading { get; set; }
        public string Range { get; set; }
        public string Status { get; set; }
        public string Updated { get; set; }
    }

    class AlertModel
    {
        public string Title { get; set; }
        public string Message { get; set; }
        public string Priority { get; set; }
    }

    class DeviceModel
    {
        public string Icon { get; set; }
        public string Name { get; set; }
        public string Type { get; set; }
        public string Battery { get; set; }
        public string Sync { get; set; }
        public string Status { get; set; }
    }

    List<ReadingModel> Readings = new()
    {
        new() { Icon="🩺", Device="BP Monitor", Type="Blood Pressure", Reading="124/82", Range="90/60 - 130/85", Status="Normal", Updated="2 mins ago" },
        new() { Icon="❤️", Device="Heart Monitor", Type="Pulse", Reading="78 bpm", Range="60 - 100", Status="Normal", Updated="1 min ago" },
        new() { Icon="🩸", Device="Glucose Monitor", Type="Sugar", Reading="108 mg/dL", Range="80 - 140", Status="Normal", Updated="5 mins ago" },
        new() { Icon="⚖️", Device="Weight Scale", Type="Weight", Reading="72 kg", Range="Healthy", Status="Stable", Updated="10 mins ago" }
    };

    List<AlertModel> Alerts = new()
    {
        new() { Title="Medication Reminder", Message="Take evening glucose reading", Priority="Medium" },
        new() { Title="Battery Alert", Message="Device battery low", Priority="High" },
        new() { Title="Follow-up", Message="Doctor review pending", Priority="Normal" }
    };

    List<DeviceModel> Devices = new()
    {
        new() { Icon="🩺", Name="BP Monitor X", Type="BP", Battery="84%", Sync="Online", Status="Connected" },
        new() { Icon="❤️", Name="Pulse Sensor", Type="Heart Rate", Battery="68%", Sync="Online", Status="Connected" },
        new() { Icon="🩸", Name="Gluco Device", Type="Glucose", Battery="45%", Sync="Online", Status="Connected" },
        new() { Icon="⚖️", Name="Weight Scale", Type="Weight", Battery="18%", Sync="Offline", Status="Warning" }
    };
}