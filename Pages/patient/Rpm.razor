@page "/patient/rpm"
@layout PatientLayout

<h2 class="page-title">Remote Patient Monitoring</h2>

<div class="rpm-container">

    <!-- SUMMARY -->
    <div class="summary-grid">

        <div class="summary-card">
            <h5>Today's Readings</h5>
            <h2>6</h2>
            <span>Synced Successfully</span>
        </div>

        <div class="summary-card">
            <h5>Connected Devices</h5>
            <h2>4</h2>
            <span>All Active</span>
        </div>

        <div class="summary-card">
            <h5>Health Score</h5>
            <h2>92%</h2>
            <span>Excellent Condition</span>
        </div>

        <div class="summary-card">
            <h5>Care Team Alerts</h5>
            <h2>2</h2>
            <span>Pending Review</span>
        </div>

    </div>

    <!-- DEVICE READINGS -->
    <div class="card">

        <div class="card-header">
            <h3>Live Device Readings</h3>

            <button class="btn-primary">
                Sync Devices
            </button>
        </div>

        <table class="styled-table">

            <thead>
                <tr>
                    <th>Device</th>
                    <th>Reading</th>
                    <th>Normal Range</th>
                    <th>Status</th>
                    <th>Last Updated</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var d in Readings)
                {
                    <tr>

                        <td>
                            <div class="device-info">

                                <div class="device-icon">
                                    @d.Icon
                                </div>

                                <div>
                                    <strong>@d.Device</strong>
                                    <span>@d.Type</span>
                                </div>

                            </div>
                        </td>

                        <td>
                            <strong>@d.Reading</strong>
                        </td>

                        <td>@d.Range</td>

                        <td>
                            <span class="status @d.Status.ToLower()">
                                @d.Status
                            </span>
                        </td>

                        <td>@d.Updated</td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

    <!-- DAILY METRICS -->
    <div class="metrics-grid">

        <div class="metric-card">

            <h4>Blood Pressure</h4>

            <div class="metric-value">
                124/82
            </div>

            <span class="metric-good">
                Stable
            </span>

        </div>

        <div class="metric-card">

            <h4>Heart Rate</h4>

            <div class="metric-value">
                78 bpm
            </div>

            <span class="metric-good">
                Normal
            </span>

        </div>

        <div class="metric-card">

            <h4>Blood Sugar</h4>

            <div class="metric-value">
                108 mg/dL
            </div>

            <span class="metric-good">
                Controlled
            </span>

        </div>

        <div class="metric-card">

            <h4>Weight</h4>

            <div class="metric-value">
                72 kg
            </div>

            <span class="metric-good">
                Healthy
            </span>

        </div>

    </div>

    <!-- ALERTS -->
    <div class="card">

        <div class="card-header">
            <h3>Care Team Notifications</h3>
        </div>

        <div class="alert-list">

            @foreach (var a in Alerts)
            {
                <div class="alert-item">

                    <div>

                        <h5>@a.Title</h5>

                        <p>@a.Message</p>

                    </div>

                    <span class="priority @a.Priority.ToLower()">
                        @a.Priority
                    </span>

                </div>
            }

        </div>

    </div>

    <!-- DEVICES -->
    <div class="card">

        <div class="card-header">
            <h3>Connected RPM Devices</h3>
        </div>

        <div class="device-grid">

            @foreach (var d in Devices)
            {
                <div class="device-card">

                    <div class="device-top">

                        <div class="device-big-icon">
                            @d.Icon
                        </div>

                        <span class="status @d.Status.ToLower()">
                            @d.Status
                        </span>

                    </div>

                    <h4>@d.Name</h4>

                    <p>@d.Type</p>

                    <div class="device-stats">

                        <div>
                            <label>Battery</label>
                            <strong>@d.Battery</strong>
                        </div>

                        <div>
                            <label>Sync</label>
                            <strong>@d.Sync</strong>
                        </div>

                    </div>

                    <button class="btn-secondary full-btn">
                        Manage Device
                    </button>

                </div>
            }

        </div>

    </div>

</div>

@code {

    class ReadingModel
    {
        public string Icon { get; set; }
        public string Device { get; set; }
        public string Type { get; set; }
        public string Reading { get; set; }
        public string Range { get; set; }
        public string Status { get; set; }
        public string Updated { get; set; }
    }

    class AlertModel
    {
        public string Title { get; set; }
        public string Message { get; set; }
        public string Priority { get; set; }
    }

    class DeviceModel
