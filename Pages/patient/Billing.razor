@page "/patient/billing"
@layout PatientLayout

<h4>Billing & Payments</h4>

<div class="billing-container">

    <!-- 🔹 SUMMARY -->
    <div class="summary-row">
        <div class="summary-card">
            <h6>Total Due</h6>
            <h4>$@TotalDue</h4>
        </div>

        <div class="summary-card">
            <h6>Paid</h6>
            <h4>$@TotalPaid</h4>
        </div>

        <div class="summary-card">
            <h6>Insurance Covered</h6>
            <h4>$@InsuranceCovered</h4>
        </div>
    </div>

    <!-- 🔹 TABLE -->
    <div class="table-card">
        <h4>Invoice List</h4>

        <table class="styled-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Date</th>
                    <th>Provider</th>
                    <th>Service</th>
                    <th>Total</th>
                    <th>Allowed</th>
                    <th>Insurance</th>
                    <th>Copay</th>
                    <th>Deductible</th>
                    <th>Patient Pay</th>
                    <th>Status</th>
                    <th>EOB</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var inv in Invoices)
                {
                    <tr>
                        <td>@inv.Id</td>
                        <td>@inv.Date.ToShortDateString()</td>
                        <td>@inv.Provider</td>
                        <td>@inv.Service</td>
                        <td>$@inv.Total</td>
                        <td>$@inv.Allowed</td>
                        <td>$@inv.Insurance</td>
                        <td>$@inv.Copay</td>
                        <td>$@inv.Deductible</td>
                        <td>$@inv.PatientPay</td>
                        <td>
                            <span class="status @inv.Status.ToLower()">@inv.Status</span>
                        </td>

                        <td>
                            <button class="btn-secondary" @onclick="() => ToggleEOB(inv)">
                                View
                            </button>
                        </td>

                        <td>
                            @if (inv.Status != "Paid")
                            {
                                <button class="btn-primary" @onclick="() => OpenPayModal(inv)">
                                    Pay
                                </button>
                            }
                            else
                            {
                                <span class="paid-text">✔ Paid</span>
                            }
                        </td>
                    </tr>

                    @if (inv.ShowEOB)
                    {
                        <tr class="eob-row">
                            <td colspan="13">
                                <div class="eob-box">
                                    <p><b>Payer:</b> @inv.Payer</p>
                                    <p><b>Claim ID:</b> @inv.ClaimId</p>
                                    <p><b>Adjustment:</b> $@inv.Adjustment</p>
                                    <p><b>Reason:</b> @inv.Reason</p>
                                    <p><b>Processed Date:</b> @inv.ProcessedDate.ToShortDateString()</p>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- 🔴 PAY MODAL -->
@if (ShowPayModal && SelectedInvoice != null)
{
    <div class="modal-overlay">
        <div class="modal-box">

            <h3>Confirm Payment</h3>

            <p>Are you sure you want to pay invoice <b>@SelectedInvoice.Id</b>?</p>

            <div class="modal-details">
                <p><b>Service:</b> @SelectedInvoice.Service</p>
                <p><b>Amount:</b> $@SelectedInvoice.PatientPay</p>
                <p><b>Provider:</b> @SelectedInvoice.Provider</p>
            </div>

            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn-primary" @onclick="ConfirmPay">Confirm Pay</button>
            </div>

        </div>
    </div>
}

