@page "/patient/orders"
@layout PatientLayout
@inject NavigationManager Nav

<div class="records-container">

    <!-- PAGE HEADER -->
    <div class="page-header">
        <div>
            <h2 class="page-title">Orders</h2>
            <p class="page-subtitle">Reports, visits and prescriptions in one place</p>
        </div>
    </div>

    <!-- TABS -->
    <div class="tabs">
        <div class="@Tab("reports")" @onclick='() => ActiveTab = "reports"'>Reports</div>
        <div class="@Tab("visits")" @onclick='() => ActiveTab = "visits"'>Visit Summaries</div>
        <div class="@Tab("prescriptions")" @onclick='() => ActiveTab = "prescriptions"'>Prescriptions</div>
    </div>

    <!-- REPORTS -->
    @if (ActiveTab == "reports")
    {
        <div class="card">

            <table class="styled-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Report Type</th>
                        <th>Provider</th>
                        <th>Status</th>
                        <th>File</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var r in Reports)
                    {
                        <tr>
                            <td>@r.Date.ToShortDateString()</td>
                            <td>@r.Type</td>
                            <td>@r.Provider</td>
                            <td>
                                <span class="status completed">Completed</span>
                            </td>
                            <td>@r.FileName</td>
                            <td>
                                <button class="btn-small"
                                        @onclick='() => DownloadPdf("medical_reports_analytics.pdf")'>
                                    Download
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- VISITS -->
    @if (ActiveTab == "visits")
    {
        <div class="card">

            <table class="styled-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Doctor</th>
                        <th>Specialty</th>
                        <th>Diagnosis</th>
                        <th>Notes</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var v in Visits)
                    {
                        <tr>
                            <td>@v.Date.ToShortDateString()</td>
                            <td>@v.Doctor</td>
                            <td>@v.Specialty</td>
                            <td>@v.Diagnosis</td>
                            <td class="notes-cell">@v.Notes</td>
                            <td>
                                <button class="btn-small">Download</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- PRESCRIPTIONS -->
    @if (ActiveTab == "prescriptions")
    {
        <div class="card">

            <table class="styled-table">
                <thead>
                    <tr>
                        <th>Medication</th>
                        <th>Dosage</th>
                        <th>Frequency</th>
                        <th>Prescribed By</th>
                        <th>Status</th>
                        <th>Refill</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var p in Prescriptions)
                    {
                        <tr>
                            <td class="strong">@p.Medication</td>
                            <td>@p.Dosage</td>
                            <td>@p.Frequency</td>
                            <td>@p.Doctor</td>
                            <td>
                                <span class="status @p.Status.ToLower()">
                                    @p.Status
                                </span>
                            </td>
                            <td>
                                <button class="btn-primary"
                                        @onclick="() => RequestRefill(p)">
                                    Request Refill
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    }

</div>

<!-- ================= MODAL (ADDED ONLY) ================= -->
@if (ShowRefillModal)
{
    <div class="modal-backdrop">
        <div class="modal-box">

            <h3>Request Refill</h3>

            <p>
                Do you want to request refill for:
                <strong>@SelectedPrescription?.Medication</strong> ?
            </p>

            <div class="modal-actions">
                <button class="btn-primary" @onclick="CloseModal">
                    Cancel
                </button>

                <button class="btn-primary" @onclick="ConfirmRefill">
                    Confirm
                </button>
            </div>

        </div>
    </div>
}

@code {

    string ActiveTab = "reports";
    string Tab(string t) => ActiveTab == t ? "tab active" : "tab";

    // 🔹 YOUR DATA (UNCHANGED)
    class Report { public DateTime Date { get; set; } public string Type { get; set; } public string Provider { get; set; } public string Status { get; set; } public string FileName { get; set; } }
    class VisitSummary { public DateTime Date { get; set; } public string Doctor { get; set; } public string Specialty { get; set; } public string Diagnosis { get; set; } public string Notes { get; set; } }
    class Prescription { public string Medication { get; set; } public string Dosage { get; set; } public string Frequency { get; set; } public string Doctor { get; set; } public string Status { get; set; } }

    List<Report> Reports = new()
    {
        new() { Date=DateTime.Today.AddDays(-1), Type="CBC", Provider="Dr. John Smith", Status="Completed", FileName="cbc.pdf"},
        new() { Date=DateTime.Today.AddDays(-3), Type="X-Ray Chest", Provider="Dr. Emily Brown", Status="Completed", FileName="xray.pdf"},
        new() { Date=DateTime.Today.AddDays(-5), Type="MRI Brain", Provider="Dr. Michael Lee", Status="Completed", FileName="mri.pdf"},
        new() { Date=DateTime.Today.AddDays(-7), Type="Lipid Profile", Provider="Dr. Sarah Adams", Status="Completed", FileName="lipid.pdf"},
        new() { Date=DateTime.Today.AddDays(-10), Type="Blood Sugar", Provider="Dr. Robert Wilson", Status="Completed", FileName="sugar.pdf"},
        new() { Date=DateTime.Today.AddDays(-12), Type="Thyroid", Provider="Dr. Emma Davis", Status="Completed", FileName="thyroid.pdf"},
        new() { Date=DateTime.Today.AddDays(-15), Type="Urine Test", Provider="Dr. Olivia Martinez", Status="Completed", FileName="urine.pdf"}
    };

    List<VisitSummary> Visits = new()
    {
        new() { Date=DateTime.Today.AddDays(-1), Doctor="Dr. Emily Brown", Specialty="Dermatology", Diagnosis="Rash", Notes="Ointment prescribed" },
        new() { Date=DateTime.Today.AddDays(-3), Doctor="Dr. John Smith", Specialty="General", Diagnosis="Fever", Notes="Paracetamol advised" },
        new() { Date=DateTime.Today.AddDays(-7), Doctor="Dr. Michael Lee", Specialty="Neurology", Diagnosis="Migraine", Notes="Reduce screen time" },
        new() { Date=DateTime.Today.AddDays(-10), Doctor="Dr. Sarah Adams", Specialty="Cardiology", Diagnosis="Hypertension", Notes="BP monitoring" },
        new() { Date=DateTime.Today.AddDays(-14), Doctor="Dr. Robert Wilson", Specialty="Ortho", Diagnosis="Knee Pain", Notes="Physiotherapy" },
        new() { Date=DateTime.Today.AddDays(-20), Doctor="Dr. Emma Davis", Specialty="Endo", Diagnosis="Thyroid", Notes="Continue meds" },
        new() { Date=DateTime.Today.AddDays(-30), Doctor="Dr. Olivia Martinez", Specialty="Urology", Diagnosis="UTI", Notes="Antibiotics 5 days" }
    };

    List<Prescription> Prescriptions = new()
    {
        new() { Medication="Amoxicillin", Dosage="500mg", Frequency="2x daily", Doctor="Dr. Emily Brown", Status="Active"},
        new() { Medication="Metformin", Dosage="850mg", Frequency="Daily", Doctor="Dr. Sarah Adams", Status="Active"},
        new() { Medication="Atorvastatin", Dosage="10mg", Frequency="Night", Doctor="Dr. John Smith", Status="Active"},
        new() { Medication="Levothyroxine", Dosage="50mcg", Frequency="Morning", Doctor="Dr. Emma Davis", Status="Active"},
        new() { Medication="Ibuprofen", Dosage="400mg", Frequency="PRN", Doctor="Dr. Robert Wilson", Status="Completed"},
        new() { Medication="Sumatriptan", Dosage="50mg", Frequency="Migraine", Doctor="Dr. Michael Lee", Status="Active"},
        new() { Medication="Ciprofloxacin", Dosage="250mg", Frequency="2x daily", Doctor="Dr. Olivia Martinez", Status="Completed"}
    };

    // ================= MODAL STATE (ADDED ONLY) =================
    bool ShowRefillModal = false;
    Prescription? SelectedPrescription;

    void RequestRefill(Prescription p)
    {
        SelectedPrescription = p;
        ShowRefillModal = true;
    }

    void CloseModal()
    {
        ShowRefillModal = false;
        SelectedPrescription = null;
    }

    void ConfirmRefill()
    {
        Console.WriteLine($"Refill requested: {SelectedPrescription?.Medication}");

        ShowRefillModal = false;
        SelectedPrescription = null;
    }

    void DownloadPdf(string fileName)
    {
        Nav.NavigateTo($"/files/{fileName}", true);
    }
}