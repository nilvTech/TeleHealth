@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="layout">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <div class="logo">
            TeleMed
        </div>

        <nav class="menu">

            <a class="@Active("admin/dashboard")"
               @onclick="@(() => Go("admin/dashboard"))">
                Dashboard
            </a>

            <a class="@Active("admin/providers")"
               @onclick="@(() => Go("admin/providers"))">
                Providers
            </a>

            <a class="@Active("admin/patients")"
               @onclick="@(() => Go("admin/patients"))">
                Patients
            </a>

            <a class="@Active("admin/devices")"
               @onclick="@(() => Go("admin/devices"))">
                Devices
            </a>

            <a class="@Active("admin/billing")"
               @onclick="@(() => Go("admin/billing"))">
                Billing & Claims
            </a>

            <a class="@Active("admin/analytics")"
               @onclick="@(() => Go("admin/analytics"))">
                Reports & Analytics
            </a>

            <a class="@Active("admin/audit")"
               @onclick="@(() => Go("admin/audit"))">
                Compliance & Audit Logs
            </a>

            <a class="@Active("admin/roles")"
               @onclick="@(() => Go("admin/roles"))">
                Role & Access Management
            </a>

            <a class="@Active("admin/settings")"
               @onclick="@(() => Go("admin/settings"))">
                Settings
            </a>

            <a @onclick="@(() => Go("/"))">
                Logout
            </a>

        </nav>

    </aside>

    <!-- MAIN -->
    <div class="main">

        <div class="topbar">

            <div class="user-info">

                <div class="user-avatar">
                    MB
                </div>

                <span class="user-name">
                    Admin User
                </span>

            </div>

        </div>

        <main class="content">
            @Body
        </main>

    </div>

</div>

@code {

    void Go(string url)
    {
        Nav.NavigateTo(url);
    }

    string Active(string url)
    {
        return Nav.Uri.ToLower().Contains(url.ToLower())
            ? "active"
            : "";
    }

}